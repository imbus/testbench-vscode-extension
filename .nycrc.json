{
    "all": true,
    "include": ["out/src/**/*.js"],
    "exclude": ["out/test/**", "out/src/test/**", "**/*.d.ts"],
    "reporter": ["text", "text-summary", "html", "lcov"],
    "sourceMap": true,
    "instrument": true,
    "report-dir": "./coverage",
    "temp-dir": "./.nyc_output",
    "require": ["source-map-support/register"],
    "check-coverage": true,
    "branches": 80,
    "lines": 80,
    "functions": 80,
    "statements": 80
}
