{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "npm",
            "script": "compile",
            "group": "build",
            "problemMatcher": ["$tsc"],
            "label": "npm: compile",
            "detail": "Runs a one-off compile task for the extension."
        },
        {
            "type": "npm",
            "script": "watch",
            "problemMatcher": "$ts-webpack-watch",
            "isBackground": true,
            "presentation": {
                "reveal": "never"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Runs webpack in watch mode for active development."
        }
    ]
}
