{
    "name": "testbench-visual-studio-code-extension",
    "publisher": "imbus",
    "displayName": "TestBench Visual Studio Code Extension",
    "description": "A Visual Studio Code extension for TestBench.",
    "icon": "resources/icons/iTB-EE-Logo-256x256.png",
    "version": "0.0.1",
    "repository": {
        "type": "git",
        "url": "https://github.com/imbus/testbench-vs-code-extension"
    },
    "engines": {
        "vscode": "^1.95.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onView:testBenchExplorer"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "configuration": [
            {
                "title": "Login",
                "properties": {
                    "testbenchExtension.serverName": {
                        "type": "string",
                        "default": "testbench",
                        "description": "The hostname or IP address of the TestBench server that the extension will connect to.",
                        "order": 1,
                        "scope": "resource"
                    },
                    "testbenchExtension.portNumber": {
                        "type": "number",
                        "default": 9445,
                        "description": "The port number on which the TestBench server is listening for incoming connections.",
                        "order": 2,
                        "scope": "resource"
                    },
                    "testbenchExtension.username": {
                        "type": "string",
                        "description": "The username used for authentication when connecting to the TestBench server.",
                        "order": 3,
                        "scope": "resource"
                    },
                    "testbenchExtension.storePasswordAfterLogin": {
                        "type": "boolean",
                        "default": false,
                        "description": "If enabled, the extension will securely store the user's password after a successful login to facilitate automatic login in future sessions without prompting for credentials.",
                        "order": 4,
                        "scope": "resource"
                    },
                    "testbenchExtension.automaticLoginAfterExtensionActivation": {
                        "type": "boolean",
                        "default": false,
                        "description": "If enabled, the extension will automatically attempt to log in to the TestBench server using the stored credentials after the extension is activated.",
                        "order": 5,
                        "scope": "resource"
                    }
                }
            },
            {
                "title": "Workspace",
                "properties": {
                    "testbenchExtension.workspaceLocation": {
                        "type": "string",
                        "description": "Specifies the absolute path to the local workspace or project directory. This directory is used for storing and processing local files during extension operations. A `.testbench` folder will be automatically created inside this directory by the extension to manage its files.",
                        "order": 6,
                        "scope": "resource"
                    },
                    "testbenchExtension.clearWorkingDirectoryBeforeTestGeneration": {
                        "type": "boolean",
                        "default": false,
                        "description": "Delete all files inside the working directory called .tesbench excluding the log files before generating tests.",
                        "order": 7,
                        "scope": "resource"
                    },
                    "testbenchExtension.clearReportAfterProcessing": {
                        "type": "boolean",
                        "default": true,
                        "description": "Remove the report file automatically after processing it.",
                        "order": 8,
                        "scope": "resource"
                    }
                }
            },
            {
                "title": "Logger",
                "properties": {
                    "testbenchExtension.testBenchLogger": {
                        "type": "string",
                        "description": "Sets the minimum log level for the extension. Logs are saved in the log folder inside the .testbench directory in the workspace location.",
                        "default": "Trace",
                        "order": 9,
                        "enum": [
                            "No logging",
                            "Trace",
                            "Debug",
                            "Info",
                            "Warn",
                            "Error"
                        ],
                        "enumDescriptions": [
                            "Disable logging",
                            "Most detailed information",
                            "Detailed information",
                            "Information messages",
                            "Warning messages",
                            "Error messages"
                        ],
                        "scope": "resource"
                    }
                }
            },
            {
                "title": "Testbench2robotframework",
                "properties": {
                    "testbenchExtension.useDefaultValuesForTestbench2robotframework": {
                        "type": "boolean",
                        "default": false,
                        "description": "Use default values for the testbench2robotframework configuration.",
                        "order": 10,
                        "scope": "resource"
                    },
                    "testbenchExtension.cleanFilesBeforeTestGenerationInTestbench2robotframework": {
                        "type": "boolean",
                        "default": true,
                        "description": "Deletes all files present in the output directory before new test suites are created.",
                        "order": 11,
                        "scope": "resource"
                    },
                    "testbenchExtension.fullyQualifiedKeywordsInTestbench2robotframework": {
                        "type": "boolean",
                        "default": false,
                        "description": "Option to call Robot Framework keywords by their fully qualified name in the generated test suites.",
                        "order": 12,
                        "scope": "resource"
                    },
                    "testbenchExtension.compoundInteractionLoggingInTestbench2robotframework": {
                        "type": "string",
                        "description": "Mode for logging compound interactions.",
                        "order": 13,
                        "default": "GROUP",
                        "enum": [
                            "GROUP",
                            "COMMENT",
                            "NONE"
                        ],
                        "enumDescriptions": [
                            "Group",
                            "Comment",
                            "None"
                        ],
                        "scope": "resource"
                    },
                    "testbenchExtension.logSuiteNumberingInTestbench2robotframework": {
                        "type": "boolean",
                        "default": false,
                        "description": "Enables logging of the test suite numbering.",
                        "order": 14,
                        "scope": "resource"
                    },
                    "testbenchExtension.resourceDirectoryPathInTestbench2robotframework": {
                        "type": "string",
                        "description": "Directory containing the Robot Framework resource files.",
                        "order": 15,
                        "scope": "resource"
                    },
                    "testbenchExtension.libraryRegexInTestbench2robotframework": {
                        "type": "array",
                        "description": "Regex that can be used to identify TestBench Subdivisions that correspond to Robot.",
                        "items": {
                            "type": "string"
                        },
                        "default": [
                            "(?:.*.)?(?P<resourceName>[^.]+?)s*[Robot-Library].*"
                        ],
                        "order": 16
                    },
                    "testbenchExtension.libraryRootInTestbench2robotframework": {
                        "type": "array",
                        "description": "TestBench root subdivision which's direct children correspond to Robot Framework.",
                        "items": {
                            "type": "string"
                        },
                        "default": [
                            "RF",
                            "RF-Library"
                        ],
                        "order": 17
                    },
                    "testbenchExtension.resourceRegexInTestbench2robotframework": {
                        "type": "array",
                        "description": "Regex that can be used to identify TestBench Subdivisions that correspond to Robot.",
                        "items": {
                            "type": "string"
                        },
                        "default": [
                            "(?:.*.)?(?P<resourceName>[^.]+?)s*[Robot-Resource].*"
                        ],
                        "order": 18
                    },
                    "testbenchExtension.resourceRootInTestbench2robotframework": {
                        "type": "array",
                        "description": "TestBench root subdivision which's direct children correspond to Robot Framework resources.",
                        "items": {
                            "type": "string"
                        },
                        "default": [
                            "RF-Resource"
                        ],
                        "order": 19
                    },
                    "testbenchExtension.libraryMappingInTestbench2robotframework": {
                        "type": "array",
                        "description": "Library mapping.",
                        "items": {
                            "type": "string"
                        },
                        "default": [],
                        "order": 20
                    },
                    "testbenchExtension.resourceMappingInTestbench2robotframework": {
                        "type": "array",
                        "description": "Resource mapping.",
                        "items": {
                            "type": "string"
                        },
                        "default": [],
                        "order": 21
                    },
                    "testbenchExtension.testbench2robotframeworkConfig": {
                        "type": "object",
                        "default": {
                            "library-root": [
                                "Interactions",
                                "RF-Library"
                            ],
                            "resource-root": [
                                "RF-Resource"
                            ],
                            "fully-qualified": false,
                            "output-directory": "{workspaceFolder}/Generated",
                            "log-suite-numbering": true,
                            "resource-directory": "{workspaceFolder}/Resources",
                            "clean": true,
                            "compound-interaction-logging": "GROUP",
                            "library-mapping": {
                                "SeleniumLibrary": "SeleniumLibrary    timeout=10    implicit_wait=1    run_on_failure=Capture Page Screenshot",
                                "SuperRemoteLibrary": "Remote    http://127.0.0.1:8270       WITH NAME    SuperRemoteLibrary"
                            },
                            "resource-mapping": {
                                "MyKeywords": "{root}/../MyKeywords.resource",
                                "MyOtherKeywords": "{resourceDirectory}/subdir/MyOtherKeywords.resource"
                            },
                            "forcedImport": {
                                "libraries": [],
                                "resources": [],
                                "variables": []
                            },
                            "testCaseSplitPathRegEx": "^StopWithRestart\\..*",
                            "console-logging": {
                                "logLevel": "debug"
                            },
                            "file-logging": {
                                "logLevel": "info"
                            }
                        },
                        "description": "(TO BE REMOVED) Configuration setting for customizing the testbench2robotframework library options.",
                        "properties": {
                            "rfLibraryRoots": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                },
                                "default": [
                                    "Interactions",
                                    "RF-Library"
                                ],
                                "description": "List of Robot Framework library root directories."
                            },
                            "rfResourceRoots": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                },
                                "default": [
                                    "RF-Resource"
                                ],
                                "description": "List of Robot Framework resource root directories."
                            },
                            "fullyQualified": {
                                "type": "boolean",
                                "default": true,
                                "description": "Use fully qualified names."
                            },
                            "generationDirectory": {
                                "type": "string",
                                "default": "{root}/Generated",
                                "description": "Directory where files will be generated."
                            },
                            "createOutputZip": {
                                "type": "boolean",
                                "default": true,
                                "description": "Create a ZIP file of the output."
                            },
                            "resourceDirectory": {
                                "type": "string",
                                "default": "{root}/Resources",
                                "description": "Directory for resources."
                            },
                            "clearGenerationDirectory": {
                                "type": "boolean",
                                "default": true,
                                "description": "Clear the generation directory before generating new files."
                            },
                            "logSuiteNumbering": {
                                "type": "boolean",
                                "default": true,
                                "description": "Log suite numbering."
                            },
                            "logCompoundInteractions": {
                                "type": "string",
                                "default": "GROUP",
                                "description": "Log compound interactions."
                            },
                            "subdivisionsMapping": {
                                "type": "object",
                                "description": "Mappings for subdivisions.",
                                "properties": {
                                    "libraries": {
                                        "type": "object",
                                        "additionalProperties": {
                                            "type": "string"
                                        },
                                        "default": {
                                            "SeleniumLibrary": "SeleniumLibrary    timeout=10    implicit_wait=1    run_on_failure=Capture Page Screenshot",
                                            "SuperRemoteLibrary": "Remote    http://127.0.0.1:8270       WITH NAME    SuperRemoteLibrary"
                                        },
                                        "description": "Library mappings."
                                    },
                                    "resources": {
                                        "type": "object",
                                        "additionalProperties": {
                                            "type": "string"
                                        },
                                        "default": {
                                            "MyKeywords": "{root}/../MyKeywords.resource",
                                            "MyOtherKeywords": "{resourceDirectory}/subdir/MyOtherKeywords.resource"
                                        },
                                        "description": "Resource mappings."
                                    }
                                }
                            },
                            "forcedImport": {
                                "type": "object",
                                "description": "Forced imports configuration.",
                                "properties": {
                                    "libraries": {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        },
                                        "default": [],
                                        "description": "List of libraries to force import."
                                    },
                                    "resources": {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        },
                                        "default": [],
                                        "description": "List of resources to force import."
                                    },
                                    "variables": {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        },
                                        "default": [],
                                        "description": "List of variables to force import."
                                    }
                                }
                            },
                            "testCaseSplitPathRegEx": {
                                "type": "string",
                                "default": "^StopWithRestart\\..*",
                                "description": "Regex pattern to split test cases."
                            },
                            "loggingConfiguration": {
                                "type": "object",
                                "description": "Logging configuration settings.",
                                "properties": {
                                    "console": {
                                        "type": "object",
                                        "description": "Console logging configuration.",
                                        "properties": {
                                            "logLevel": {
                                                "type": "string",
                                                "default": "info",
                                                "description": "Log level for console output."
                                            }
                                        }
                                    }
                                }
                            }
                        },
                        "order": 11,
                        "scope": "resource"
                    },
                    "testbenchExtension.outputXmlFilePath": {
                        "type": "string",
                        "description": "The absolute file path where the output XML file (Robotframework test results) is stored. If not set, the extension will prompt the user to select a output.xml file location when uploading results to testbench server.",
                        "order": 12,
                        "scope": "resource"
                    }
                }
            }
        ],
        "commands": [
            {
                "command": "testbenchExtension.toggleWebViewVisibility",
                "title": "Testbench: Toggle Login Web View Visibility"
            },
            {
                "command": "testbenchExtension.login",
                "title": "Testbench: Login",
                "icon": {
                    "light": "resources/icons/login.svg",
                    "dark": "resources/icons/login.svg"
                }
            },
            {
                "command": "testbenchExtension.logout",
                "title": "Testbench: Logout",
                "icon": {
                    "light": "resources/icons/logout.svg",
                    "dark": "resources/icons/logout.svg"
                }
            },
            {
                "command": "testbenchExtension.setWorkspaceLocation",
                "title": "TestBench: Set Workspace Location"
            },
            {
                "command": "testbenchExtension.clearWorkspaceFolder",
                "title": "TestBench: Clear Workspace Folder",
                "icon": {
                    "light": "resources/icons/clearWorkspaceFolder.svg",
                    "dark": "resources/icons/clearWorkspaceFolder.svg"
                }
            },
            {
                "command": "testbenchExtension.toggleProjectManagementTreeViewVisibility",
                "title": "TestBench: Toggle Project Tree View Visibility"
            },
            {
                "command": "testbenchExtension.toggleTestThemeTreeViewVisibility",
                "title": "TestBench: Toggle Test Theme Tree View Visibility"
            },
            {
                "command": "testbenchExtension.generateTestCasesForCycle",
                "title": "Generate Tests",
                "icon": {
                    "light": "resources/icons/robot_dark.svg",
                    "dark": "resources/icons/robot_dark.svg"
                }
            },
            {
                "command": "testbenchExtension.generateTestCasesForTestThemeOrTestCaseSet",
                "title": "Generate Tests",
                "icon": {
                    "light": "resources/icons/robot_dark.svg",
                    "dark": "resources/icons/robot_dark.svg"
                }
            },
            {
                "command": "testbenchExtension.fetchReportForSelectedTreeItem",
                "title": "Fetch Report",
                "icon": {
                    "light": "resources/icons/download.svg",
                    "dark": "resources/icons/download.svg"
                }
            },
            {
                "command": "testbenchExtension.makeRoot",
                "title": "TestBench: Make root"
            },
            {
                "command": "testbenchExtension.selectAndLoadProject",
                "title": "TestBench: Display Projects List",
                "icon": {
                    "light": "resources/icons/menu.svg",
                    "dark": "resources/icons/menu.svg"
                }
            },
            {
                "command": "testbenchExtension.readRFTestResultsAndCreateReportWithResults",
                "title": "TestBench: Read Test Results & Create Report With Results",
                "icon": {
                    "light": "resources/icons/read.svg",
                    "dark": "resources/icons/read.svg"
                }
            },
            {
                "command": "testbenchExtension.refreshProjectTreeView",
                "title": "TestBench: Refresh Project Tree View",
                "when": "view == projectManagementTree",
                "icon": {
                    "light": "resources/icons/refresh.svg",
                    "dark": "resources/icons/refresh.svg"
                }
            },
            {
                "command": "testbenchExtension.refreshTestThemeTreeView",
                "title": "TestBench: Refresh Test Tree View",
                "when": "view == testThemeTree",
                "icon": {
                    "light": "resources/icons/refresh.svg",
                    "dark": "resources/icons/refresh.svg"
                }
            },
            {
                "command": "testbenchExtension.displayCommands",
                "title": "TestBench: Display Commands",
                "icon": {
                    "light": "resources/icons/more.svg",
                    "dark": "resources/icons/more.svg"
                }
            },
            {
                "command": "testbenchExtension.showExtensionSettings",
                "title": "TestBench: Show Extension Settings",
                "icon": {
                    "light": "resources/icons/settings.svg",
                    "dark": "resources/icons/settings.svg"
                }
            },
            {
                "command": "testbenchExtension.readAndUploadTestResultsToTestbench",
                "title": "TestBench: Read Tests & Upload Results To Testbench",
                "icon": {
                    "light": "resources/icons/Upload.svg",
                    "dark": "resources/icons/Upload.svg"
                }
            },
            {
                "command": "testbenchExtension.uploadTestResultsToTestbench",
                "title": "TestBench: Upload Test Results To Testbench",
                "icon": {
                    "light": "resources/icons/Upload.svg",
                    "dark": "resources/icons/Upload.svg"
                }
            }
        ],
        "views": {
            "testBenchExplorer": [
                {
                    "type": "webview",
                    "id": "testbenchExtension.webView",
                    "name": "Login to TestBench"
                },
                {
                    "id": "projectManagementTree",
                    "name": "Project Management Tree"
                },
                {
                    "id": "testThemeTree",
                    "name": "Test Theme Tree"
                },
                {
                    "id": "testElementsTreeView",
                    "name": "Test Elements Tree"
                }
            ]
        },
        "menus": {
            "view/title": [
                {
                    "command": "testbenchExtension.login",
                    "group": "navigation@1",
                    "title": "Testbench: Login",
                    "when": "!testbenchExtension.connectionActive && (view == projectManagementTree)",
                    "icon": {
                        "light": "resources/icons/login.svg",
                        "dark": "resources/icons/login.svg"
                    }
                },
                {
                    "command": "testbenchExtension.logout",
                    "group": "navigation@2",
                    "title": "Testbench: Logout",
                    "when": "testbenchExtension.connectionActive && (view == projectManagementTree)",
                    "icon": {
                        "light": "resources/icons/logout.svg",
                        "dark": "resources/icons/logout.svg"
                    }
                },
                {
                    "command": "testbenchExtension.refreshProjectTreeView",
                    "group": "navigation@3",
                    "when": "view == projectManagementTree"
                },
                {
                    "command": "testbenchExtension.selectAndLoadProject",
                    "group": "navigation@4",
                    "when": "view == projectManagementTree"
                },
                {
                    "command": "testbenchExtension.refreshTestThemeTreeView",
                    "group": "navigation@5",
                    "when": "view == testThemeTree"
                },
                {
                    "command": "testbenchExtension.readAndUploadTestResultsToTestbench",
                    "group": "navigation@6",
                    "when": "view == projectManagementTree || view == testThemeTree"
                },
                {
                    "command": "testbenchExtension.clearWorkspaceFolder",
                    "group": "navigation@7",
                    "when": "view == projectManagementTree"
                },
                {
                    "command": "testbenchExtension.showExtensionSettings",
                    "group": "navigation@8",
                    "when": "view == projectManagementTree || view == testbenchExtension.webView"
                }
            ],
            "view/item/context": [
                {
                    "command": "testbenchExtension.generateTestCasesForCycle",
                    "when": "view == projectManagementTree && viewItem == Cycle",
                    "group": "inline@1"
                },
                {
                    "command": "testbenchExtension.generateTestCasesForTestThemeOrTestCaseSet",
                    "when": "view == testThemeTree && (viewItem == TestThemeNode || viewItem == TestCaseSetNode)",
                    "group": "inline@2"
                },
                {
                    "command": "testbenchExtension.makeRoot",
                    "when": "(view == projectManagementTree || view == testThemeTree) && (viewItem == Project || viewItem == tov || viewItem == Version || viewItem == TestThemeNode)",
                    "group": "navigation"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "testBenchExplorer",
                    "title": "TestBench",
                    "icon": "resources/icons/TBU_Logo_cropped.svg"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "webpack",
        "watch": "webpack --watch",
        "package": "webpack --mode production --devtool hidden-source-map",
        "compile-tests": "tsc -p . --outDir out --incremental",
        "watch-tests": "tsc -p . -w --outDir out --incremental",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "lint": "eslint --config eslint.config.mjs .",
        "test": "node ./out/test/runTest.js"
    },
    "devDependencies": {
        "@types/glob": "^8.1.0",
        "@types/mocha": "^10.0.9",
        "@types/node": "^22.7.5",
        "@types/sinon": "^17.0.3",
        "@types/vscode": "^1.95.0",
        "@typescript-eslint/eslint-plugin": "^8.9.0",
        "@typescript-eslint/parser": "^8.9.0",
        "@vscode/test-cli": "^0.0.10",
        "@vscode/test-electron": "^2.4.1",
        "eslint": "^9.12.0",
        "mocha": "^10.7.3",
        "proxyquire": "^2.1.3",
        "sinon": "^19.0.2",
        "ts-loader": "^9.5.1",
        "typescript": "^5.6.3",
        "webpack": "^5.95.0",
        "webpack-cli": "^5.1.4"
    },
    "dependencies": {
        "@vscode-elements/elements": "^1.10.0",
        "@vscode/python-extension": "^1.0.5",
        "axios": "^1.7.7",
        "flatted": "^3.3.1",
        "jszip": "^3.10.1"
    },
    "extensionDependencies": [
        "ms-python.python"
    ]
}
