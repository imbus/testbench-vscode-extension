{
    "name": "testbench-extension",
    "publisher": "imbus",
    "displayName": "TestBench",
    "description": "A Visual Studio Code extension for imbus TestBench.",
    "icon": "resources/icons/testbench-logo.png",
    "version": "0.6.2",
    "repository": {
        "type": "git",
        "url": "https://github.com/imbus/testbench-vscode-extension"
    },
    "engines": {
        "vscode": "^1.101.0"
    },
    "homepage": "https://github.com/imbus/testbench-vscode-extension",
    "bugs": {
        "url": "https://github.com/imbus/testbench-vscode-extension/issues",
        "email": "support@imbus.de"
    },
    "keywords": [
        "TestBench",
        "imbus",
        "testing",
        "test automation",
        "robot framework"
    ],
    "license": "Apache-2.0",
    "categories": [
        "Testing"
    ],
    "files": [
        "dist/extension.js",
        "dist/extension.js.LICENSE.txt",
        "dist/webview/**",
        "bundled/**",
        "resources/icons/**",
        "README.md",
        "LICENSE",
        "userGuideImages/**"
    ],
    "activationEvents": [],
    "main": "./dist/extension.js",
    "contributes": {
        "authentication": [
            {
                "label": "TestBench",
                "id": "testbench-auth"
            }
        ],
        "configuration": [
            {
                "id": "login",
                "title": "Login",
                "properties": {
                    "testbenchExtension.automaticLoginAfterExtensionActivation": {
                        "type": "boolean",
                        "default": false,
                        "description": "If enabled, the extension will automatically attempt to log in to the TestBench server using the last used connection after the extension is activated. Auto-login only occurs when there are stored connections and a last used connection is available.",
                        "order": 1,
                        "scope": "resource"
                    }
                }
            },
            {
                "id": "logger",
                "title": "Logger",
                "properties": {
                    "testbenchExtension.testbenchLogLevel": {
                        "type": "string",
                        "description": "Sets the minimum log level for the extension. Logs are saved in the log folder inside the .testbench directory within the workspace.",
                        "default": "Info",
                        "order": 9,
                        "enum": [
                            "No logging",
                            "Trace",
                            "Debug",
                            "Info",
                            "Warn",
                            "Error"
                        ],
                        "enumDescriptions": [
                            "Disable logging",
                            "Most detailed information",
                            "Detailed information",
                            "Information messages",
                            "Warning messages",
                            "Error messages"
                        ],
                        "scope": "resource"
                    }
                }
            },
            {
                "id": "testbench2robotframework",
                "title": "TestBench2RobotFramework",
                "_disabledSettings": {
                    "testbenchExtension.UseConfigurationFile": {
                        "type": "boolean",
                        "propertyNames": true,
                        "description": "If enabled, testbench2robotframework will prioritize the settings specified in the pyproject.toml over those specified in the extension settings.",
                        "default": false,
                        "order": 10,
                        "scope": "window",
                        "_note": "Temporarily disabled due to bug with tree item marking after test generation. Move back to 'properties' when fixed. (tbe-162)"
                    }
                },
                "properties": {
                    "testbenchExtension.cleanFilesBeforeTestGeneration": {
                        "type": "boolean",
                        "default": true,
                        "description": "Deletes all files present in the output directory before new test suites are created.",
                        "order": 11,
                        "scope": "window"
                    },
                    "testbenchExtension.fullyQualifiedKeywords": {
                        "type": "boolean",
                        "default": false,
                        "description": "Option to call Robot Framework keywords by their fully qualified name in the generated test suites.",
                        "order": 12,
                        "scope": "window"
                    },
                    "testbenchExtension.outputDirectory": {
                        "type": "string",
                        "description": "Directory or ZIP archive where the generated test suites will be created. The path is relative to the workspace location.",
                        "default": "tests",
                        "order": 13,
                        "scope": "window"
                    },
                    "testbenchExtension.compoundKeywordLogging": {
                        "type": "string",
                        "description": "Mode for logging compound TestBench keywords.",
                        "order": 14,
                        "default": "GROUP",
                        "enum": [
                            "GROUP",
                            "COMMENT",
                            "NONE"
                        ],
                        "enumDescriptions": [
                            "Group",
                            "Comment",
                            "None"
                        ],
                        "scope": "window"
                    },
                    "testbenchExtension.logSuiteNumbering": {
                        "type": "boolean",
                        "default": true,
                        "description": "Enables logging of the test suite numbering.",
                        "order": 15,
                        "scope": "window"
                    },
                    "testbenchExtension.resourceDirectoryPath": {
                        "type": "string",
                        "description": "Directory containing the Robot Framework resource files. The path is relative to the workspace location. Import paths of Robot Framework resources will be prefixed with this path.",
                        "order": 16,
                        "default": "",
                        "scope": "window"
                    },
                    "testbenchExtension.libraryMarker": {
                        "type": "array",
                        "description": "Marker that can be used to identify TestBench Subdivisions that correspond to Robot Framework libraries. Subdivisions that end with this marker will be considered as Robot Framework libraries.",
                        "items": {
                            "type": "string"
                        },
                        "default": [
                            "[Robot-Library]"
                        ],
                        "order": 17,
                        "scope": "window"
                    },
                    "testbenchExtension.libraryRoot": {
                        "type": "array",
                        "description": "TestBench root subdivision whose direct children correspond to Robot Framework resources.",
                        "items": {
                            "type": "string"
                        },
                        "default": [
                            "RF",
                            "RF-Library"
                        ],
                        "order": 18,
                        "scope": "window"
                    },
                    "testbenchExtension.resourceRootRegex": {
                        "type": "string",
                        "description": "A regular expression used to identify the TestBench subdivision that corresponds to the subdivision containing all Robot Framework keywords. This matching subdivision becomes the anchor point when creating the folder structure and import paths for resources in the generated Robot files. Any subdivisions above and including the matched subdivision are ignored.",
                        "default": ".*",
                        "order": 19,
                        "scope": "window"
                    },
                    "testbenchExtension.resourceMarker": {
                        "type": "array",
                        "description": "Marker that can be used to identify TestBench Subdivisions that correspond to Robot Framework resources. Subdivisions that end with this marker will be considered as Robot Framework resources.",
                        "items": {
                            "type": "string"
                        },
                        "default": [
                            "[Robot-Resource]"
                        ],
                        "order": 20,
                        "scope": "window"
                    },
                    "testbenchExtension.resourceRoot": {
                        "type": "array",
                        "description": "TestBench root subdivision whose direct children correspond to Robot Framework resources.",
                        "items": {
                            "type": "string"
                        },
                        "default": [
                            "RF-Resource"
                        ],
                        "order": 21,
                        "scope": "window"
                    },
                    "testbenchExtension.libraryMapping": {
                        "type": "array",
                        "markdownDescription": "Optional mapping of TestBench Subdivisions to Robot Framework libraries. Must be specified in the format:\n`<TestBench Subdivision Name>:<Robot Framework Library import>`",
                        "items": {
                            "type": "string"
                        },
                        "default": [],
                        "order": 22,
                        "scope": "window"
                    },
                    "testbenchExtension.resourceMapping": {
                        "type": "array",
                        "markdownDescription": "Optional mapping of TestBench Subdivisions to Robot Framework resources. Must be specified in the format:\n`<TestBench Subdivision Name>:<Robot Framework Resource import>.`",
                        "items": {
                            "type": "string"
                        },
                        "default": [],
                        "order": 23,
                        "scope": "window"
                    },
                    "testbenchExtension.outputXmlFilePath": {
                        "type": "string",
                        "description": "The relative file path where the output XML file (Robotframework test results) is stored. If not set, the extension will prompt the user to select a output.xml file location when importing results to testbench server. The path is relative to the workspace location. Used for importing the test results to the TestBench Server.",
                        "default": "results/output.xml",
                        "order": 24,
                        "scope": "window"
                    }
                }
            },
            {
                "id": "testGeneration",
                "title": "Test Generation",
                "properties": {
                    "testbenchExtension.clearInternalTestbenchDirectoryBeforeTestGeneration": {
                        "type": "boolean",
                        "default": false,
                        "description": "Deletes all files, excluding log files and project config file, from the internal `.testbench` directory before generating tests.",
                        "order": 1,
                        "scope": "resource"
                    },
                    "testbenchExtension.openTestingViewAfterTestGeneration": {
                        "type": "boolean",
                        "description": "If enabled, the testing view will be opened automatically after test generation is completed.",
                        "default": false,
                        "order": 1,
                        "scope": "window"
                    }
                }
            },
            {
                "id": "connection",
                "title": "Connection",
                "properties": {
                    "testbenchExtension.certificatePath": {
                        "type": "string",
                        "description": "Path to the public TestBench certificate .pem file. Can be either an absolute path or a path relative to the workspace location.",
                        "order": 1,
                        "scope": "resource"
                    }
                }
            }
        ],
        "commands": [
            {
                "command": "testbenchExtension.login",
                "title": "Login / Switch Connection",
                "icon": {
                    "light": "resources/icons/login.svg",
                    "dark": "resources/icons/login.svg"
                }
            },
            {
                "command": "testbenchExtension.logout",
                "title": "Logout",
                "icon": {
                    "light": "resources/icons/logout.svg",
                    "dark": "resources/icons/logout.svg"
                }
            },
            {
                "command": "testbenchExtension.clearInternalTestbenchFolder",
                "title": "Clear Temporary Files"
            },
            {
                "command": "testbenchExtension.generateTestCasesForCycle",
                "title": "Generate Robot Framework Test Suites (Cycle based)",
                "icon": {
                    "light": "resources/icons/robot-light.svg",
                    "dark": "resources/icons/robot-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.generateTestCasesForTestThemeOrTestCaseSet",
                "title": "Generate Robot Framework Test Suites",
                "icon": {
                    "light": "resources/icons/robot-light.svg",
                    "dark": "resources/icons/robot-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.generateTestsForTestThemeTreeItemFromTOV",
                "title": "Generate Robot Framework Test Suites",
                "icon": {
                    "light": "resources/icons/robot-light.svg",
                    "dark": "resources/icons/robot-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.openAndRevealGeneratedRobotFile",
                "title": "Open Generated Test Suite",
                "icon": {
                    "light": "resources/icons/open-light.svg",
                    "dark": "resources/icons/open-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.generateTestCasesForTOV",
                "title": "Generate Robot Framework Test Suites (TOV based)",
                "icon": {
                    "light": "resources/icons/robot-light.svg",
                    "dark": "resources/icons/robot-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.openTOVFromProjectsView",
                "title": "Open Test Object Version",
                "icon": {
                    "light": "resources/icons/open-light.svg",
                    "dark": "resources/icons/open-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.openCycleFromProjectsView",
                "title": "Open Test Cycle",
                "icon": {
                    "light": "resources/icons/open-light.svg",
                    "dark": "resources/icons/open-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.fetchTovStructure",
                "title": "TestBench: Get TOV Structure"
            },
            {
                "command": "testbenchExtension.displayAllProjects",
                "title": "Open Projects View",
                "icon": {
                    "light": "resources/icons/menu-light.svg",
                    "dark": "resources/icons/menu-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.refreshProjectTreeView",
                "title": "Refresh Projects",
                "when": "view == projectManagementTree",
                "icon": {
                    "light": "resources/icons/refresh-light.svg",
                    "dark": "resources/icons/refresh-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.refreshTestThemeTreeView",
                "title": "Refresh Test Themes",
                "when": "view == testThemeTree",
                "group": "navigation@1",
                "icon": {
                    "light": "resources/icons/refresh-light.svg",
                    "dark": "resources/icons/refresh-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.displayFiltersForTestThemeTreeDisabled",
                "title": "Display Test Theme Filters",
                "when": "view == testbench.testThemes && !testbenchExtension.testThemeTreeHasFilters",
                "icon": {
                    "light": "resources/icons/filter-off-light.svg",
                    "dark": "resources/icons/filter-off-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.displayFiltersForTestThemeTreeEnabled",
                "title": "Display Test Theme Filters",
                "when": "view == testbench.testThemes && testbenchExtension.testThemeTreeHasFilters",
                "icon": {
                    "light": "resources/icons/filter-on-light.svg",
                    "dark": "resources/icons/filter-on-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.enableFilterDiffMode",
                "title": "Filter Diff Disabled",
                "icon": {
                    "light": "resources/icons/diff-off-light.svg",
                    "dark": "resources/icons/diff-off-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.disableFilterDiffMode",
                "title": "Filter Diff Enabled",
                "icon": {
                    "light": "resources/icons/diff-on-light.svg",
                    "dark": "resources/icons/diff-on-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.showExtensionSettings",
                "title": "Open Extension Settings",
                "icon": {
                    "light": "resources/icons/settings-light.svg",
                    "dark": "resources/icons/settings-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.readAndImportTestResultsToTestbench",
                "title": "Upload Execution Results To TestBench",
                "icon": {
                    "light": "resources/icons/upload-light.svg",
                    "dark": "resources/icons/upload-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.importTestResultsToTestbench",
                "title": "Upload Execution Results To TestBench",
                "icon": {
                    "light": "resources/icons/upload-light.svg",
                    "dark": "resources/icons/upload-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.refreshTestElementsTree",
                "title": "Refresh Test Elements",
                "when": "view == testbench.testElements",
                "group": "navigation",
                "icon": {
                    "light": "resources/icons/refresh-light.svg",
                    "dark": "resources/icons/refresh-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.openAvailableSubdivisionInTestElementsView",
                "title": "Open Resource",
                "when": "view == testbench.testElements && viewItem == 'testElement.subdivision.resource.available'",
                "icon": {
                    "light": "resources/icons/open-light.svg",
                    "dark": "resources/icons/open-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.openMissingSubdivisionInTestElementsView",
                "title": "Create Resource",
                "when": "view == testbench.testElements && viewItem == 'testElement.subdivision.resource.missing'",
                "icon": "$(new-file)"
            },
            {
                "command": "testbenchExtension.openSubdivisionFolderInExplorer",
                "title": "Open in Explorer View",
                "when": "view == testbench.testElements && viewItem == 'testElement.subdivision.folder'",
                "icon": {
                    "light": "resources/icons/open-light.svg",
                    "dark": "resources/icons/open-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.openKeywordInTestElementsView",
                "title": "Open Resource",
                "when": "view == testbench.testElements && viewItem == 'testElement.keyword.resource.available'",
                "icon": {
                    "light": "resources/icons/open-light.svg",
                    "dark": "resources/icons/open-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.createMissingParentResourceForKeyword",
                "title": "Create Resource",
                "when": "view == testbench.testElements && viewItem == 'testElement.keyword.resource.missing'",
                "icon": "$(new-file)"
            },
            {
                "command": "testbenchExtension.openIssueReporter",
                "title": "TestBench: Open Issue Reporter"
            },
            {
                "command": "testbenchExtension.checkForCycleDoubleClick",
                "title": "Handle Cycle Click"
            },
            {
                "command": "testbenchExtension.clearAllExtensionData",
                "title": "TestBench: Clear All Extension Data"
            },
            {
                "command": "testbenchExtension.searchInProjectsTreeOff",
                "title": "Search",
                "icon": {
                    "light": "resources/icons/search-off-light.svg",
                    "dark": "resources/icons/search-off-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.searchInProjectsTreeOn",
                "title": "Search",
                "icon": {
                    "light": "resources/icons/search-on-light.svg",
                    "dark": "resources/icons/search-on-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.searchInTestThemesTreeOff",
                "title": "Search",
                "icon": {
                    "light": "resources/icons/search-off-light.svg",
                    "dark": "resources/icons/search-off-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.searchInTestThemesTreeOn",
                "title": "Search",
                "icon": {
                    "light": "resources/icons/search-on-light.svg",
                    "dark": "resources/icons/search-on-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.searchInTestElementsTreeOff",
                "title": "Search",
                "icon": {
                    "light": "resources/icons/search-off-light.svg",
                    "dark": "resources/icons/search-off-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.searchInTestElementsTreeOn",
                "title": "Search",
                "icon": {
                    "light": "resources/icons/search-on-light.svg",
                    "dark": "resources/icons/search-on-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.setActiveProject",
                "title": "Set as Active Project"
            },
            {
                "command": "testbenchExtension.setActiveTOV",
                "title": "Set as Active TOV"
            },
            {
                "command": "testbenchExtension.validateAndFixLsConfig",
                "title": "TestBench: Validate and Fix Project Configuration"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "testBenchExplorer",
                    "title": "TestBench",
                    "icon": "resources/icons/testbench-logo.png"
                }
            ]
        },
        "views": {
            "testBenchExplorer": [
                {
                    "type": "webview",
                    "id": "testbenchExtension.webView",
                    "name": "Login to TestBench",
                    "when": "!testbenchExtension.connectionActive",
                    "icon": "resources/icons/login.svg"
                },
                {
                    "id": "testbench.projects",
                    "name": "Projects",
                    "when": "testbenchExtension.connectionActive && testbenchExtension.showProjectsTree",
                    "icon": "resources/icons/project-dark.svg"
                },
                {
                    "id": "testbench.testThemes",
                    "name": "Test Themes",
                    "when": "testbenchExtension.connectionActive && testbenchExtension.showTestThemesTree",
                    "icon": "resources/icons/TestThemeOriginal-dark.svg"
                },
                {
                    "id": "testbench.testElements",
                    "name": "Test Elements",
                    "when": "testbenchExtension.connectionActive && testbenchExtension.showTestElementsTree",
                    "icon": "resources/icons/test-elements-dark.svg"
                }
            ]
        },
        "menus": {
            "commandPalette": [
                {
                    "command": "testbenchExtension.fetchTovStructure",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.displayAllProjects",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.refreshProjectTreeView",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.refreshTestThemeTreeView",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.showExtensionSettings",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.readAndImportTestResultsToTestbench",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.importTestResultsToTestbench",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.refreshTestElementsTree",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.openAvailableSubdivisionInTestElementsView",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.openMissingSubdivisionInTestElementsView",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.openSubdivisionFolderInExplorer",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.openKeywordInTestElementsView",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.createMissingParentResourceForKeyword",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.checkForCycleDoubleClick",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.validateAndFixLsConfig",
                    "when": "false"
                }
            ],
            "view/title": [
                {
                    "command": "testbenchExtension.login",
                    "group": "navigation@1",
                    "title": "Login",
                    "when": "!testbenchExtension.connectionActive && (view == testbench.projects)",
                    "icon": {
                        "light": "resources/icons/login.svg",
                        "dark": "resources/icons/login.svg"
                    }
                },
                {
                    "command": "testbenchExtension.logout",
                    "group": "navigation@2",
                    "title": "Logout",
                    "when": "testbenchExtension.connectionActive && (view == testbench.projects)",
                    "icon": {
                        "light": "resources/icons/logout.svg",
                        "dark": "resources/icons/logout.svg"
                    }
                },
                {
                    "command": "testbenchExtension.refreshProjectTreeView",
                    "group": "navigation@3",
                    "when": "view == testbench.projects",
                    "icon": {
                        "light": "resources/icons/refresh-light.svg",
                        "dark": "resources/icons/refresh-dark.svg"
                    }
                },
                {
                    "command": "testbenchExtension.searchInProjectsTreeOff",
                    "when": "view == testbench.projects && !testbenchExtension.projectsTreeHasSearchFilter",
                    "group": "navigation@4",
                    "icon": {
                        "light": "resources/icons/search-off-light.svg",
                        "dark": "resources/icons/search-off-dark.svg"
                    }
                },
                {
                    "command": "testbenchExtension.searchInProjectsTreeOn",
                    "when": "view == testbench.projects && testbenchExtension.projectsTreeHasSearchFilter",
                    "group": "navigation@4",
                    "icon": {
                        "light": "resources/icons/search-on-light.svg",
                        "dark": "resources/icons/search-on-dark.svg"
                    }
                },
                {
                    "command": "testbenchExtension.displayAllProjects",
                    "group": "navigation@2",
                    "when": "view == testbench.testThemes",
                    "icon": {
                        "light": "resources/icons/menu-light.svg",
                        "dark": "resources/icons/menu-dark.svg"
                    }
                },
                {
                    "command": "testbenchExtension.displayAllProjects",
                    "group": "navigation@2",
                    "when": "view == testbench.testElements",
                    "icon": {
                        "light": "resources/icons/menu-light.svg",
                        "dark": "resources/icons/menu-dark.svg"
                    }
                },
                {
                    "command": "testbenchExtension.refreshTestThemeTreeView",
                    "group": "navigation@1",
                    "when": "view == testbench.testThemes",
                    "icon": {
                        "light": "resources/icons/refresh-light.svg",
                        "dark": "resources/icons/refresh-dark.svg"
                    }
                },
                {
                    "command": "testbenchExtension.displayFiltersForTestThemeTreeDisabled",
                    "when": "view == testbench.testThemes && !testbenchExtension.testThemeTreeHasFilters && false",
                    "group": "navigation@3",
                    "icon": {
                        "light": "resources/icons/filter-off-light.svg",
                        "dark": "resources/icons/filter-off-dark.svg"
                    }
                },
                {
                    "command": "testbenchExtension.displayFiltersForTestThemeTreeEnabled",
                    "when": "view == testbench.testThemes && testbenchExtension.testThemeTreeHasFilters && false",
                    "group": "navigation@3",
                    "icon": {
                        "light": "resources/icons/filter-on-light.svg",
                        "dark": "resources/icons/filter-on-dark.svg"
                    }
                },
                {
                    "command": "testbenchExtension.enableFilterDiffMode",
                    "when": "view == testbench.testThemes && testbenchExtension.testThemeTreeHasFilters && !testbenchExtension.filterDiffModeEnabledTestThemes && false",
                    "group": "navigation@4",
                    "icon": {
                        "light": "resources/icons/diff-off-light.svg",
                        "dark": "resources/icons/diff-off-dark.svg"
                    }
                },
                {
                    "command": "testbenchExtension.disableFilterDiffMode",
                    "when": "view == testbench.testThemes && testbenchExtension.testThemeTreeHasFilters && testbenchExtension.filterDiffModeEnabledTestThemes && false",
                    "group": "navigation@4",
                    "icon": {
                        "light": "resources/icons/diff-on-light.svg",
                        "dark": "resources/icons/diff-on-dark.svg"
                    }
                },
                {
                    "command": "testbenchExtension.searchInTestThemesTreeOff",
                    "when": "view == testbench.testThemes && !testbenchExtension.testThemesTreeHasSearchFilter",
                    "group": "navigation@5",
                    "icon": {
                        "light": "resources/icons/search-off-light.svg",
                        "dark": "resources/icons/search-off-dark.svg"
                    }
                },
                {
                    "command": "testbenchExtension.searchInTestThemesTreeOn",
                    "when": "view == testbench.testThemes && testbenchExtension.testThemesTreeHasSearchFilter",
                    "group": "navigation@5",
                    "icon": {
                        "light": "resources/icons/search-on-light.svg",
                        "dark": "resources/icons/search-on-dark.svg"
                    }
                },
                {
                    "command": "testbenchExtension.showExtensionSettings",
                    "group": "navigation@9",
                    "when": "view == testbench.projects || view == testbenchExtension.webView"
                },
                {
                    "command": "testbenchExtension.refreshTestElementsTree",
                    "title": "Refresh Test Elements",
                    "when": "view == testbench.testElements",
                    "group": "navigation",
                    "icon": {
                        "light": "resources/icons/refresh-light.svg",
                        "dark": "resources/icons/refresh-dark.svg"
                    }
                },
                {
                    "command": "testbenchExtension.searchInTestElementsTreeOff",
                    "when": "view == testbench.testElements && !testbenchExtension.testElementsTreeHasSearchFilter",
                    "group": "navigation@3",
                    "icon": {
                        "light": "resources/icons/search-off-light.svg",
                        "dark": "resources/icons/search-off-dark.svg"
                    }
                },
                {
                    "command": "testbenchExtension.searchInTestElementsTreeOn",
                    "when": "view == testbench.testElements && testbenchExtension.testElementsTreeHasSearchFilter",
                    "group": "navigation@3",
                    "icon": {
                        "light": "resources/icons/search-on-light.svg",
                        "dark": "resources/icons/search-on-dark.svg"
                    }
                }
            ],
            "view/item/context": [
                {
                    "command": "testbenchExtension.generateTestCasesForCycle",
                    "when": "view == testbench.projects && viewItem == Cycle && testbenchExtension.workspaceAvailable",
                    "group": "inline@1"
                },
                {
                    "command": "testbenchExtension.openCycleFromProjectsView",
                    "when": "view == testbench.projects && viewItem == Cycle",
                    "group": "inline@2"
                },
                {
                    "command": "testbenchExtension.generateTestCasesForTOV",
                    "when": "view == testbench.projects && viewItem == Version && testbenchExtension.workspaceAvailable",
                    "group": "inline@1"
                },
                {
                    "command": "testbenchExtension.openTOVFromProjectsView",
                    "when": "view == testbench.projects && viewItem == Version",
                    "group": "inline@2"
                },
                {
                    "command": "testbenchExtension.generateTestCasesForTestThemeOrTestCaseSet",
                    "when": "view == 'testbench.testThemes' && testbenchExtension.isTestThemeOpenedFromCycle && testbenchExtension.workspaceAvailable && viewItem =~ /(TestThemeNode|TestCaseSetNode)(\\.hasRobotFile)?$/",
                    "group": "inline@1"
                },
                {
                    "command": "testbenchExtension.generateTestsForTestThemeTreeItemFromTOV",
                    "when": "view == 'testbench.testThemes' && !testbenchExtension.isTestThemeOpenedFromCycle && testbenchExtension.workspaceAvailable && viewItem =~ /(TestThemeNode|TestCaseSetNode)(\\.hasRobotFile)?$/",
                    "group": "inline@2"
                },
                {
                    "command": "testbenchExtension.openAndRevealGeneratedRobotFile",
                    "when": "view == 'testbench.testThemes' && testbenchExtension.workspaceAvailable && viewItem =~ /\\.hasRobotFile$/",
                    "group": "inline@3"
                },
                {
                    "command": "testbenchExtension.readAndImportTestResultsToTestbench",
                    "when": "view == 'testbench.testThemes' && testbenchExtension.workspaceAvailable && viewItem =~ /MarkedForImport/",
                    "group": "inline@2",
                    "icon": {
                        "light": "resources/icons/upload-light.svg",
                        "dark": "resources/icons/upload-dark.svg"
                    }
                },
                {
                    "command": "testbenchExtension.openAvailableSubdivisionInTestElementsView",
                    "when": "view == testbench.testElements && testbenchExtension.workspaceAvailable && viewItem == 'testElement.subdivision.resource.available'",
                    "group": "inline@1"
                },
                {
                    "command": "testbenchExtension.openMissingSubdivisionInTestElementsView",
                    "when": "view == testbench.testElements && testbenchExtension.workspaceAvailable && viewItem == 'testElement.subdivision.resource.missing'",
                    "group": "inline@1"
                },
                {
                    "command": "testbenchExtension.openSubdivisionFolderInExplorer",
                    "when": "view == testbench.testElements && testbenchExtension.workspaceAvailable && viewItem == 'testElement.subdivision.folder'",
                    "group": "inline@1"
                },
                {
                    "command": "testbenchExtension.openKeywordInTestElementsView",
                    "when": "view == testbench.testElements && testbenchExtension.workspaceAvailable && viewItem == 'testElement.keyword.resource.available'",
                    "group": "inline@1"
                },
                {
                    "command": "testbenchExtension.createMissingParentResourceForKeyword",
                    "when": "view == testbench.testElements && testbenchExtension.workspaceAvailable && viewItem == 'testElement.keyword.resource.missing'",
                    "group": "inline@1"
                },
                {
                    "command": "testbenchExtension.setActiveProject",
                    "when": "view == testbench.projects && viewItem == Project && testbenchExtension.workspaceAvailable",
                    "group": "navigation@2"
                },
                {
                    "command": "testbenchExtension.setActiveTOV",
                    "when": "view == testbench.projects && viewItem == Version && testbenchExtension.workspaceAvailable",
                    "group": "navigation@2"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "tsc -p ./",
        "watch": "webpack --watch",
        "package": "webpack --mode production --devtool hidden-source-map",
        "vsix-package": "vsce package",
        "clean-tests": "node scripts/clean-tests.js",
        "compile-tests": "npm run clean-tests && tsc -p ./",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile",
        "test": "node ./out/test/runTest.js",
        "test:ui": "npm run compile-tests && node out/test/ui/runners/runUITests.js",
        "test:ui-single": "npm run compile-tests && node out/test/ui/runners/runUITests.js",
        "test:ui-profile": "npm run compile-tests && node out/test/ui/runners/runUITestsWithProfiles.js",
        "test:ui-all-profiles": "npm run compile-tests && node out/test/ui/runners/runUITestsWithProfiles.js",
        "test:ui-list-profiles": "node src/test/ui/config/listProfiles.js",
        "test:ui-interactive": "node scripts/run-profile-test.js",
        "test:ui-setup": "extest setup-tests",
        "test:ui-run": "npm run compile-tests && extest run-tests out/test/ui/**/*.ui.test.js",
        "prettier-format": "prettier --config .prettierrc 'src/**/*.ts' --write",
        "lint": "eslint --config eslint.config.mjs .",
        "prepare": "husky",
        "release": "semantic-release",
        "commit:cz": "git-cz",
        "test:unit": "npm run compile-tests && mocha ./out/test/suite/**/*.test.js --timeout 10000",
        "test:coverage": "npm run compile-tests && nyc --reporter=lcov --reporter=text mocha ./out/test/suite/**/*.test.js --timeout 10000",
        "format:check": "prettier --check .",
        "commit:helper": "node scripts/commit.js",
        "release:manual": "node scripts/manual-release.js"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.1.0",
        "@commitlint/config-conventional": "^20.0.0",
        "@eslint/js": "^9.20.0",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/exec": "^7.1.0",
        "@semantic-release/git": "^10.0.1",
        "@semantic-release/github": "^11.0.3",
        "@semantic-release/npm": "^12.0.1",
        "@types/base-64": "^1.0.2",
        "@types/chai": "^4.3.20",
        "@types/mocha": "^10.0.10",
        "@types/node": "^22.18.12",
        "@types/sinon": "^17.0.4",
        "@types/uuid": "^10.0.0",
        "@types/vscode": "^1.101.0",
        "@typescript-eslint/eslint-plugin": "^8.9.0",
        "@typescript-eslint/parser": "^8.9.0",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "^3.9.1",
        "chai": "^4.5.0",
        "conventional-changelog-conventionalcommits": "^9.1.0",
        "copy-webpack-plugin": "^13.0.1",
        "dotenv": "^17.2.3",
        "eslint": "^9.29.0",
        "globals": "^16.4.0",
        "husky": "^9.1.7",
        "mocha": "^11.7.4",
        "mocha-junit-reporter": "^2.2.1",
        "nyc": "^17.1.0",
        "prettier": "^3.5.3",
        "semantic-release": "^24.2.5",
        "sinon": "^21.0.0",
        "ts-loader": "^9.5.2",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.34.1",
        "vscode-extension-tester": "^8.22.0",
        "webpack": "^5.99.9",
        "webpack-cli": "^6.0.1"
    },
    "dependencies": {
        "@vscode/python-extension": "^1.0.5",
        "axios": "^1.10.0",
        "base-64": "^1.0.0",
        "fast-deep-equal": "^3.1.3",
        "flatted": "^3.3.3",
        "https-proxy-agent": "^7.0.6",
        "jszip": "^3.10.1",
        "uuid": "^9.0.1",
        "vscode-languageclient": "^9.0.1"
    },
    "extensionDependencies": [
        "ms-python.python",
        "d-biehl.robotcode"
    ],
    "lint-staged": {
        "**/*": "prettier --write --ignore-unknown",
        "*.ts": "eslint --fix"
    }
}
