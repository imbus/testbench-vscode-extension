{
    "name": "testbench-extension",
    "publisher": "imbus",
    "displayName": "TestBench Extension",
    "description": "A Visual Studio Code extension for TestBench.",
    "icon": "resources/icons/testbench-logo.png",
    "version": "0.0.1",
    "repository": {
        "type": "git",
        "url": "https://github.com/imbus/testbench-vs-code-extension"
    },
    "engines": {
        "vscode": "^1.95.0"
    },
    "homepage": "https://github.com/imbus/testbench-vs-code-extension",
    "bugs": {
        "url": "https://github.com/imbus/testbench-vs-code-extension/issues",
        "email": "egegirit@imbus.de"
    },
    "keywords": [
        "TestBench",
        "imbus",
        "testing",
        "test automation",
        "robot framework"
    ],
    "pricing": "Free",
    "license": "SEE LICENSE IN LICENSE.md",
    "categories": [
        "Testing"
    ],
    "activationEvents": [
        "onView:testBenchExplorer"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "authentication": [
            {
                "label": "TestBench",
                "id": "testbench-auth"
            }
        ],
        "configuration": [
            {
                "title": "Login",
                "properties": {
                    "testbenchExtension.automaticLoginAfterExtensionActivation": {
                        "type": "boolean",
                        "default": false,
                        "description": "If enabled, the extension will automatically attempt to log in to the TestBench server using the last used connection after the extension is activated.",
                        "order": 1,
                        "scope": "resource"
                    }
                }
            },
            {
                "title": "Working Directory",
                "properties": {
                    "testbenchExtension.clearInternalTestbenchDirectoryBeforeTestGeneration": {
                        "type": "boolean",
                        "default": false,
                        "description": "Delete all files excluding the log files inside the working directory called .testbench before generating tests.",
                        "order": 7,
                        "scope": "resource"
                    },
                    "testbenchExtension.clearReportAfterProcessing": {
                        "type": "boolean",
                        "default": true,
                        "description": "Remove the report file automatically after processing it.",
                        "order": 8,
                        "scope": "resource"
                    }
                }
            },
            {
                "title": "Logger",
                "properties": {
                    "testbenchExtension.testBenchLogger": {
                        "type": "string",
                        "description": "Sets the minimum log level for the extension. Logs are saved in the log folder inside the .testbench directory in the workspace location.",
                        "default": "Trace",
                        "order": 9,
                        "enum": [
                            "No logging",
                            "Trace",
                            "Debug",
                            "Info",
                            "Warn",
                            "Error"
                        ],
                        "enumDescriptions": [
                            "Disable logging",
                            "Most detailed information",
                            "Detailed information",
                            "Information messages",
                            "Warning messages",
                            "Error messages"
                        ],
                        "scope": "resource"
                    }
                }
            },
            {
                "title": "TestBench2RobotFramework",
                "properties": {
                    "testbenchExtension.UseConfigurationFile": {
                        "type": "boolean",
                        "propertyNames": true,
                        "description": "If enabled, testbench2robotframework will prioritize the settings specified in the pyproject.toml over those specified in the extension settings.",
                        "default": false,
                        "order": 10,
                        "scope": "window"
                    },
                    "testbenchExtension.cleanFilesBeforeTestGeneration": {
                        "type": "boolean",
                        "default": true,
                        "description": "Deletes all files present in the output directory before new test suites are created.",
                        "order": 11,
                        "scope": "window"
                    },
                    "testbenchExtension.fullyQualifiedKeywords": {
                        "type": "boolean",
                        "default": false,
                        "description": "Option to call Robot Framework keywords by their fully qualified name in the generated test suites.",
                        "order": 12,
                        "scope": "window"
                    },
                    "testbenchExtension.outputDirectory": {
                        "type": "string",
                        "description": "Directory or ZIP archive containing the generated test suites. The path is relative to the workspace location.",
                        "order": 13,
                        "scope": "window"
                    },
                    "testbenchExtension.compoundInteractionLogging": {
                        "type": "string",
                        "description": "Mode for logging compound TestBench interactions.",
                        "order": 14,
                        "default": "GROUP",
                        "enum": [
                            "GROUP",
                            "COMMENT",
                            "NONE"
                        ],
                        "enumDescriptions": [
                            "Group",
                            "Comment",
                            "None"
                        ],
                        "scope": "window"
                    },
                    "testbenchExtension.logSuiteNumbering": {
                        "type": "boolean",
                        "default": false,
                        "description": "Enables logging of the test suite numbering.",
                        "order": 15,
                        "scope": "window"
                    },
                    "testbenchExtension.resourceDirectoryPath": {
                        "type": "string",
                        "description": "Directory containing the Robot Framework resource files. The path is relative to the workspace location.",
                        "order": 16,
                        "scope": "window"
                    },
                    "testbenchExtension.libraryMarker": {
                        "type": "array",
                        "description": "Marker that can be used to identify TestBench Subdivisions that correspond to Robot Framework libraries. Subdivisions that end with this marker will be considered as Robot Framework libraries.",
                        "items": {
                            "type": "string"
                        },
                        "default": [
                            "[Robot-Library]"
                        ],
                        "order": 17,
                        "scope": "window"
                    },
                    "testbenchExtension.libraryRoot": {
                        "type": "array",
                        "description": "TestBench root subdivision which's direct children correspond to Robot Framework resources.",
                        "items": {
                            "type": "string"
                        },
                        "default": [
                            "RF",
                            "RF-Library"
                        ],
                        "order": 18,
                        "scope": "window"
                    },
                    "testbenchExtension.resourceMarker": {
                        "type": "array",
                        "description": "Marker that can be used to identify TestBench Subdivisions that correspond to Robot Framework resources. Subdivisions that end with this marker will be considered as Robot Framework resources.",
                        "items": {
                            "type": "string"
                        },
                        "default": [
                            "[Robot-Resource]"
                        ],
                        "order": 19,
                        "scope": "window"
                    },
                    "testbenchExtension.resourceRoot": {
                        "type": "array",
                        "description": "TestBench root subdivision which's direct children correspond to Robot Framework resources.",
                        "items": {
                            "type": "string"
                        },
                        "default": [
                            "RF-Resource"
                        ],
                        "order": 20,
                        "scope": "window"
                    },
                    "testbenchExtension.libraryMapping": {
                        "type": "array",
                        "markdownDescription": "Optional mapping of TestBench Subdivisions to Robot Framework libraries. Must be specified in the format:\n`<TestBench Subdivision Name>:<Robot Framework Library import>`",
                        "items": {
                            "type": "string"
                        },
                        "default": [],
                        "order": 21,
                        "scope": "window"
                    },
                    "testbenchExtension.resourceMapping": {
                        "type": "array",
                        "markdownDescription": "Optional mapping of TestBench Subdivisions to Robot Framework resources. Must be specified in the format:\n`<TestBench Subdivision Name>:<Robot Framework Resource import>.`",
                        "items": {
                            "type": "string"
                        },
                        "default": [],
                        "order": 22,
                        "scope": "window"
                    },
                    "testbenchExtension.outputXmlFilePath": {
                        "type": "string",
                        "description": "The relative file path where the output XML file (Robotframework test results) is stored. If not set, the extension will prompt the user to select a output.xml file location when importing results to testbench server. The path is relative to the workspace location. Used for importing the test results to the TestBench Server.",
                        "default": "results/output.xml",
                        "order": 23,
                        "scope": "window"
                    }
                }
            }
        ],
        "commands": [
            {
                "command": "testbenchExtension.login",
                "title": "Login / Switch Connection",
                "icon": {
                    "light": "resources/icons/login.svg",
                    "dark": "resources/icons/login.svg"
                }
            },
            {
                "command": "testbenchExtension.logout",
                "title": "Logout",
                "icon": {
                    "light": "resources/icons/logout.svg",
                    "dark": "resources/icons/logout.svg"
                }
            },
            {
                "command": "testbenchExtension.clearInternalTestbenchFolder",
                "title": "Clear Temporary Files",
                "icon": {
                    "light": "resources/icons/clearInternalTestbenchFolder-light.svg",
                    "dark": "resources/icons/clearInternalTestbenchFolder-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.generateTestCasesForCycle",
                "title": "Generate Tests For Cycle",
                "icon": {
                    "light": "resources/icons/robot-light.svg",
                    "dark": "resources/icons/robot-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.generateTestCasesForTestThemeOrTestCaseSet",
                "title": "Generate Tests of Cycle",
                "icon": {
                    "light": "resources/icons/robot-light.svg",
                    "dark": "resources/icons/robot-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.generateTestCasesForTestThemeFromTOV",
                "title": "Generate Tests of TOV",
                "icon": {
                    "light": "resources/icons/robot-light.svg",
                    "dark": "resources/icons/robot-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.generateTestCasesForTOV",
                "title": "Generate Tests For TOV",
                "icon": {
                    "light": "resources/icons/robot-light.svg",
                    "dark": "resources/icons/robot-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.openTOVFromProjectsView",
                "title": "Open TOV",
                "icon": {
                    "light": "resources/icons/open-light.svg",
                    "dark": "resources/icons/open-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.openCycleFromProjectsView",
                "title": "Open Cycle",
                "icon": {
                    "light": "resources/icons/open-light.svg",
                    "dark": "resources/icons/open-dark.svg"
                }
            },
            {
                "command": "projectManagementTree.removeView",
                "title": "Hide Project Management Tree"
            },
            {
                "command": "projectManagementTree.focus",
                "title": "Focus Project Management Tree"
            },
            {
                "command": "testThemeTree.removeView",
                "title": "Hide Test Theme Tree"
            },
            {
                "command": "testThemeTree.focus",
                "title": "Focus Test Theme Tree"
            },
            {
                "command": "testElementsTree.removeView",
                "title": "Hide Test Theme Tree"
            },
            {
                "command": "testElementsTree.focus",
                "title": "Focus Test Theme Tree"
            },
            {
                "command": "testbenchExtension.makeRoot",
                "title": "Make root"
            },
            {
                "command": "testbenchExtension.resetProjectTreeViewRoot",
                "title": "Reset Project View Root"
            },
            {
                "command": "testbenchExtension.resetTestThemeTreeViewRoot",
                "title": "Reset Test Theme View Root"
            },
            {
                "command": "testbenchExtension.getFilters",
                "title": "TestBench: Get Filters"
            },
            {
                "command": "testbenchExtension.fetchTovStructure",
                "title": "TestBench: Get TOV Structure"
            },
            {
                "command": "testbenchExtension.displayAllProjects",
                "title": "Display Projects",
                "icon": {
                    "light": "resources/icons/menu-light.svg",
                    "dark": "resources/icons/menu-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.readRFTestResultsAndCreateReportWithResults",
                "title": "Read Test Results & Create Report With Results",
                "icon": {
                    "light": "resources/icons/read-light.svg",
                    "dark": "resources/icons/read-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.refreshProjectTreeView",
                "title": "Refresh Project Tree View",
                "when": "view == projectManagementTree",
                "icon": {
                    "light": "resources/icons/refresh-light.svg",
                    "dark": "resources/icons/refresh-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.refreshTestThemeTreeView",
                "title": "Refresh Test Themes",
                "when": "view == testThemeTree",
                "group": "navigation@1",
                "icon": {
                    "light": "resources/icons/refresh-light.svg",
                    "dark": "resources/icons/refresh-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.showExtensionSettings",
                "title": "Show Extension Settings",
                "icon": {
                    "light": "resources/icons/settings-light.svg",
                    "dark": "resources/icons/settings-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.readAndImportTestResultsToTestbench",
                "title": "Read Tests & Import Results To Testbench",
                "icon": {
                    "light": "resources/icons/upload-light.svg",
                    "dark": "resources/icons/upload-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.importTestResultsToTestbench",
                "title": "Import Test Results To Testbench",
                "icon": {
                    "light": "resources/icons/upload-light.svg",
                    "dark": "resources/icons/upload-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.refreshTestElementsTree",
                "title": "Refresh Test Elements",
                "group": "navigation@1",
                "icon": {
                    "light": "resources/icons/refresh-light.svg",
                    "dark": "resources/icons/refresh-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.openOrCreateRobotResourceFile",
                "title": "Go to Robot Resource"
            },
            {
                "command": "testbenchExtension.createInteractionUnderSubdivision",
                "title": "Create Interaction"
            },
            {
                "command": "testbenchExtension.openIssueReporter",
                "title": "TestBench: Open Issue Reporter"
            },
            {
                "command": "testbenchExtension.modifyReportWithResultsZip",
                "title": "TestBench: Modify Report File"
            },
            {
                "command": "testbenchExtension.setWorkspace",
                "title": "TestBench: Set Workspace"
            },
            {
                "command": "testbenchExtension.checkForCycleDoubleClick",
                "title": "Handle Cycle Click"
            }
        ],
        "views": {
            "testBenchExplorer": [
                {
                    "type": "webview",
                    "id": "testbenchExtension.webView",
                    "name": "Login to TestBench",
                    "when": "!testbenchExtension.connectionActive",
                    "icon": "resources/icons/login.svg"
                },
                {
                    "id": "projectManagementTree",
                    "name": "Projects",
                    "when": "testbenchExtension.connectionActive",
                    "icon": "resources/icons/project-dark.svg"
                },
                {
                    "id": "testThemeTree",
                    "name": "Test Themes",
                    "when": "testbenchExtension.connectionActive",
                    "icon": "resources/icons/TestThemeOriginal-dark.svg"
                },
                {
                    "id": "testElementsView",
                    "name": "Test Elements",
                    "when": "testbenchExtension.connectionActive",
                    "icon": "resources/icons/test-elements-dark.svg"
                }
            ]
        },
        "menus": {
            "view/title": [
                {
                    "command": "testbenchExtension.login",
                    "group": "navigation@1",
                    "title": "Login",
                    "when": "!testbenchExtension.connectionActive && (view == projectManagementTree)",
                    "icon": {
                        "light": "resources/icons/login.svg",
                        "dark": "resources/icons/login.svg"
                    }
                },
                {
                    "command": "testbenchExtension.logout",
                    "group": "navigation@2",
                    "title": "Logout",
                    "when": "testbenchExtension.connectionActive && (view == projectManagementTree)",
                    "icon": {
                        "light": "resources/icons/logout.svg",
                        "dark": "resources/icons/logout.svg"
                    }
                },
                {
                    "command": "testbenchExtension.refreshProjectTreeView",
                    "group": "navigation@3",
                    "when": "view == projectManagementTree",
                    "icon": {
                        "light": "resources/icons/refresh-light.svg",
                        "dark": "resources/icons/refresh-dark.svg"
                    }
                },
                {
                    "command": "testbenchExtension.displayAllProjects",
                    "group": "navigation@3",
                    "when": "view == testThemeTree",
                    "icon": {
                        "light": "resources/icons/menu-light.svg",
                        "dark": "resources/icons/menu-dark.svg"
                    }
                },
                {
                    "command": "testbenchExtension.displayAllProjects",
                    "group": "navigation@2",
                    "when": "view == testElementsView",
                    "icon": {
                        "light": "resources/icons/menu-light.svg",
                        "dark": "resources/icons/menu-dark.svg"
                    }
                },
                {
                    "command": "testbenchExtension.refreshTestThemeTreeView",
                    "group": "navigation@1",
                    "when": "view == testThemeTree",
                    "icon": {
                        "light": "resources/icons/refresh-light.svg",
                        "dark": "resources/icons/refresh-dark.svg"
                    }
                },
                {
                    "command": "testbenchExtension.showExtensionSettings",
                    "group": "navigation@8",
                    "when": "view == projectManagementTree || view == testbenchExtension.webView"
                },
                {
                    "command": "testbenchExtension.refreshTestElementsTree",
                    "when": "view == testElementsView",
                    "group": "navigation",
                    "icon": {
                        "light": "resources/icons/refresh-light.svg",
                        "dark": "resources/icons/refresh-dark.svg"
                    }
                }
            ],
            "view/item/context": [
                {
                    "command": "testbenchExtension.generateTestCasesForCycle",
                    "when": "view == projectManagementTree && viewItem == Cycle",
                    "group": "inline@1"
                },
                {
                    "command": "testbenchExtension.openCycleFromProjectsView",
                    "when": "view == projectManagementTree && viewItem == Cycle",
                    "group": "inline@2"
                },
                {
                    "command": "testbenchExtension.generateTestCasesForTOV",
                    "when": "view == projectManagementTree && (viewItem == tov || viewItem == Version)",
                    "group": "inline@1"
                },
                {
                    "command": "testbenchExtension.openTOVFromProjectsView",
                    "when": "view == projectManagementTree && (viewItem == tov || viewItem == Version)",
                    "group": "inline@2"
                },
                {
                    "command": "testbenchExtension.generateTestCasesForTestThemeOrTestCaseSet",
                    "when": "view == testThemeTree && (viewItem == 'TestThemeNode' || viewItem == 'TestCaseSetNode' || viewItem == 'MarkedForImport.TestThemeNode' || viewItem == 'MarkedForImport.TestCaseSetNode' || viewItem == 'MarkedSubForImport.TestThemeNode' || viewItem == 'MarkedSubForImport.TestCaseSetNode' || viewItem == 'customRoot.testTheme' || viewItem == 'MarkedForImport.customRoot.testTheme') && testbenchExtension.isTestThemeOpenedFromCycle",
                    "group": "inline@2"
                },
                {
                    "command": "testbenchExtension.generateTestCasesForTestThemeFromTOV",
                    "when": "view == testThemeTree && (viewItem == 'TestThemeNode' || viewItem == 'TestCaseSetNode' || viewItem == 'MarkedForImport.TestThemeNode' || viewItem == 'MarkedForImport.TestCaseSetNode' || viewItem == 'MarkedSubForImport.TestThemeNode' || viewItem == 'MarkedSubForImport.TestCaseSetNode' || viewItem == 'customRoot.testTheme' || viewItem == 'MarkedForImport.customRoot.testTheme')  && !testbenchExtension.isTestThemeOpenedFromCycle",
                    "group": "inline@2"
                },
                {
                    "command": "testbenchExtension.readAndImportTestResultsToTestbench",
                    "when": "view == testThemeTree && (viewItem == 'MarkedForImport.TestThemeNode' || viewItem == 'MarkedForImport.TestCaseSetNode' || viewItem == 'MarkedSubForImport.TestThemeNode' || viewItem == 'MarkedSubForImport.TestCaseSetNode' || viewItem == 'MarkedForImport.customRoot.testTheme') && testbenchExtension.isTestThemeOpenedFromCycle",
                    "group": "inline@1"
                },
                {
                    "command": "testbenchExtension.makeRoot",
                    "when": "(view == projectManagementTree || view == testThemeTree) && (viewItem == Project || viewItem == TestThemeNode || viewItem == 'MarkedForImport.TestThemeNode')",
                    "group": "navigation"
                },
                {
                    "command": "testbenchExtension.openOrCreateRobotResourceFile",
                    "when": "view == testElementsView && (viewItem == subdivision || viewItem == interaction)",
                    "group": "navigation"
                },
                {
                    "command": "testbenchExtension.createInteractionUnderSubdivision",
                    "when": "view == testElementsView && viewItem == subdivision",
                    "group": "1_modification"
                },
                {
                    "command": "testbenchExtension.resetProjectTreeViewRoot",
                    "when": "view == projectManagementTree && viewItem == customRoot.project",
                    "group": "navigation@1",
                    "title": "Reset Custom Root"
                },
                {
                    "command": "testbenchExtension.resetTestThemeTreeViewRoot",
                    "when": "view == testThemeTree && (viewItem == 'customRoot.testTheme' || viewItem == 'MarkedForImport.customRoot.testTheme')",
                    "group": "navigation@1",
                    "title": "Reset Custom Root"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "testBenchExplorer",
                    "title": "TestBench",
                    "icon": "resources/icons/testbench-logo.svg"
                }
            ]
        },
        "languages": [
            {
                "id": "robotframework",
                "aliases": [
                    "robotframework"
                ],
                "extensions": [
                    ".resource"
                ],
                "configuration": "./language-configuration.json"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "webpack",
        "watch": "webpack --watch",
        "package": "webpack --mode production --devtool hidden-source-map",
        "vsix-package": "vsce package",
        "compile-tests": "tsc -p . --outDir out --incremental",
        "watch-tests": "tsc -p . -w --outDir out --incremental",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "test": "node ./out/test/runTest.js",
        "prettier-format": "prettier --config .prettierrc 'src/**/*.ts' --write",
        "lint": "eslint --config eslint.config.mjs .",
        "prepare": "husky",
        "release": "semantic-release",
        "commit": "git-cz"
    },
    "release": {
        "branches": [
            "main"
        ],
        "plugins": [
            "@semantic-release/commit-analyzer",
            "@semantic-release/release-notes-generator",
            "@semantic-release/github"
        ]
    },
    "devDependencies": {
        "@eslint/js": "^9.20.0",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/exec": "^7.0.3",
        "@semantic-release/git": "^10.0.1",
        "@semantic-release/github": "^11.0.1",
        "@semantic-release/npm": "^12.0.1",
        "@types/base-64": "^1.0.2",
        "@types/glob": "^8.1.0",
        "@types/mocha": "^10.0.9",
        "@types/node": "^22.7.5",
        "@types/sinon": "^17.0.3",
        "@types/uuid": "^10.0.0",
        "@types/vscode": "^1.95.0",
        "@typescript-eslint/eslint-plugin": "^8.9.0",
        "@typescript-eslint/parser": "^8.9.0",
        "@vscode/test-cli": "^0.0.10",
        "@vscode/test-electron": "^2.4.1",
        "@vscode/vsce": "^3.4.2",
        "conventional-changelog-conventionalcommits": "^8.0.0",
        "eslint": "^9.20.1",
        "globals": "^15.15.0",
        "husky": "^9.1.7",
        "mocha": "^10.7.3",
        "prettier": "^3.5.1",
        "proxyquire": "^2.1.3",
        "semantic-release": "^24.2.3",
        "sinon": "^19.0.2",
        "ts-loader": "^9.5.1",
        "typescript": "^5.6.3",
        "typescript-eslint": "^8.24.1",
        "webpack": "^5.95.0",
        "webpack-cli": "^5.1.4"
    },
    "dependencies": {
        "@vscode-elements/elements": "^1.10.0",
        "@vscode/python-extension": "^1.0.5",
        "axios": "^1.7.7",
        "base-64": "^1.0.0",
        "flatted": "^3.3.1",
        "jszip": "^3.10.1",
        "regex-translator": "^0.2.8",
        "uuid": "^11.1.0",
        "vscode-languageclient": "^9.0.1"
    },
    "extensionDependencies": [
        "ms-python.python",
        "d-biehl.robotcode"
    ],
    "husky": {
        "hooks": {
            "pre-commit": "npx lint-staged"
        }
    },
    "lint-staged": {
        "**/*": "prettier --write --ignore-unknown",
        "*.ts": "npx tslint"
    }
}
