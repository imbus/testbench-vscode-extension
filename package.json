{
    "name": "testbench-visual-studio-code-extension",
    "publisher": "imbus",
    "displayName": "TestBench Visual Studio Code Extension",
    "description": "A Visual Studio Code extension for TestBench.",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.91.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./dist/extension.js",
    "contributes": {
        "configuration": {
            "title": "TestBench Extension Settings",
            "properties": {
                "testbenchExtension.serverName": {
                    "type": "string",
                    "default": "testbench",
                    "description": "The server name that is used to connect to the TestBench server.",
                    "order": 1
                },
                "testbenchExtension.portNumber": {
                    "type": "number",
                    "default": 9445,
                    "description": "Port Number for the TestBench server.",
                    "order": 2
                },
                "testbenchExtension.username": {
                    "type": "string",
                    "description": "Username of the user for the TestBench server.",
                    "order": 3
                },
                "testbenchExtension.storePasswordAfterLogin": {
                    "type": "boolean",
                    "default": false,
                    "description": "Store password after login for automatic login.",
                    "order": 4
                },
                "testbenchExtension.workspaceLocation": {
                    "type": "string",
                    "description": "Workspace location.",
                    "order": 5
                },
                "testbenchExtension.reportGenerationConfig": {
                    "type": "object",
                    "default": {
                        "generationDirectory": "",
                        "clearGenerationDirectory": true,
                        "createOutputZip": false,
                        "removeExtractedFiles": false
                    },
                    "description": "Configuration settings for the test generation.",
                    "properties": {
                        "generationDirectory": {
                            "type": "string",
                            "default": "",
                            "description": "Directory where files will be generated."
                        },
                        "clearGenerationDirectory": {
                            "type": "boolean",
                            "default": true,
                            "description": "Clear the generation directory after generating new files."
                        },
                        "createOutputZip": {
                            "type": "boolean",
                            "default": false,
                            "description": "Create a zip file of the output."
                        },
                        "removeExtractedFiles": {
                            "type": "boolean",
                            "default": false,
                            "description": "Remove extracted files after processing."
                        },
                        "order": 6
                    }
                }
            }
        },
        "commands": [
            {
                "command": "testbenchExtension.login",
                "title": "Testbench: Login"
            },
            {
                "command": "testbenchExtension.logout",
                "title": "Testbench: Logout"
            },
            {
                "command": "testbenchExtension.changeConnection",
                "title": "TestBench: Change Connection"
            },
            {
                "command": "testbenchExtension.initTestThemeTree",
                "title": "TestBench: Display Test Theme Tree"
            },
            {
                "command": "testbenchExtension.generateTestCases",
                "title": "Generate Test Cases"
            },
            {
                "command": "testbenchExtension.makeRoot",
                "title": "Make root"
            },
            {
                "command": "testbenchExtension.initTestThemeTree",
                "title": "Refresh Tree and Reset Root",
                "icon": {
                    "light": "resources/icons/refresh.svg",
                    "dark": "resources/icons/refresh.svg"
                }
            },
            {
                "command": "testbenchExtension.runRobotTests",
                "title": "TestBench: Run Robot Framework Tests"
            },
            {
                "command": "testbenchExtension.getCycleStructure",
                "title": "TestBench: Get Cycle Structure"
            },
            {
                "command": "testbenchExtension.displayCommands",
                "title": "TestBench: Display Commands"
            },
            {
                "command": "testbenchExtension.showExtensionSettings",
                "title": "TestBench: Show Extension Settings"
            },
            {
                "command": "testbenchExtension.getProjectList",
                "title": "TestBench: Get Project List"
            }
        ],
        "views": {
            "testBenchExplorer": [
                {
                    "id": "projectManagementTree",
                    "name": "Project Management Tree"
                },
                {
                    "id": "testThemeTree",
                    "name": "Test Theme Tree"
                }
            ]
        },
        "menus": {
            "view/title": [
                {
                    "command": "testbenchExtension.initTestThemeTree",
                    "group": "navigation"
                }
            ],
            "view/item/context": [
                {
                    "command": "testbenchExtension.generateTestCases",
                    "when": "view == projectManagementTree && viewItem == cycle",
                    "group": "inline"
                },
                {
                    "command": "testbenchExtension.makeRoot",
                    "when": "view == projectManagementTree && viewItem == project || viewItem == tov || viewItem == version || viewItem == cycle || viewItem == TestTheme || viewItem == TestCaseSet",
                    "group": "navigation"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "testBenchExplorer",
                    "title": "TestBench",
                    "icon": "resources/icons/iTB-EE-Logo-22x20.png"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "webpack",
        "watch": "webpack --watch",
        "package": "webpack --mode production --devtool hidden-source-map",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/base-64": "^1.0.2",
        "@types/cheerio": "^0.22.35",
        "@types/mocha": "^10.0.7",
        "@types/node": "20.x",
        "@types/unzipper": "^0.10.10",
        "@types/vscode": "^1.91.0",
        "@typescript-eslint/eslint-plugin": "^7.14.1",
        "@typescript-eslint/parser": "^7.11.0",
        "@vscode/test-cli": "^0.0.9",
        "@vscode/test-electron": "^2.4.0",
        "base-64": "^1.0.0",
        "eslint": "^8.57.0",
        "ts-loader": "^9.5.1",
        "typescript": "^5.4.5",
        "webpack": "^5.92.1",
        "webpack-cli": "^5.1.4"
    },
    "dependencies": {
        "axios": "^1.7.2",
        "cheerio": "^1.0.0",
        "unzipper": "^0.12.3"
    }
}
