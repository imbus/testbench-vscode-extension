{
    "name": "testbench-visual-studio-code-extension",
    "publisher": "imbus",
    "displayName": "TestBench Visual Studio Code Extension",
    "description": "A Visual Studio Code extension for TestBench.",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.91.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./dist/extension.js",
    "contributes": {
        "configuration": {
            "title": "TestBench Extension Settings",
            "properties": {
                "testbenchExtension.serverName": {
                    "type": "string",
                    "default": "testbench",
                    "description": "The hostname or IP address of the TestBench server that the extension will connect to.",
                    "order": 1
                },
                "testbenchExtension.portNumber": {
                    "type": "number",
                    "default": 9445,
                    "description": "The port number on which the TestBench server is listening for incoming connections.",
                    "order": 2
                },
                "testbenchExtension.username": {
                    "type": "string",
                    "description": "The username used for authentication when connecting to the TestBench server.",
                    "order": 3
                },
                "testbenchExtension.storePasswordAfterLogin": {
                    "type": "boolean",
                    "default": false,
                    "description": "If enabled, the extension will securely store the user's password after the first login to facilitate automatic login in future sessions without prompting for credentials.",
                    "order": 4
                },
                "testbenchExtension.workspaceLocation": {
                    "type": "string",
                    "description": "The path to the workspace or project directory on the local machine for storing local files.",
                    "order": 5
                },
                "testbenchExtension.reportGenerationConfig": {
                    "type": "object",
                    "default": {
                        "generationDirectory": "",
                        "clearGenerationDirectory": true,
                        "createOutputZip": false,
                        "removeExtractedFiles": false
                    },
                    "description": "Configuration settings for the test generation.",
                    "properties": {
                        "generationDirectory": {
                            "type": "string",
                            "default": "",
                            "description": "The directory where the files will be generated."
                        },
                        "clearGenerationDirectory": {
                            "type": "boolean",
                            "default": true,
                            "description": "Clear the generation directory after generating new files."
                        },
                        "createOutputZip": {
                            "type": "boolean",
                            "default": false,
                            "description": "Create a zip file of the output."
                        },
                        "removeExtractedFiles": {
                            "type": "boolean",
                            "default": false,
                            "description": "Remove extracted files after processing."
                        },
                        "order": 6
                    }
                }
            }
        },
        "commands": [
            {
                "command": "testbenchExtension.login",
                "title": "Testbench: Login",
                "icon": {
                    "light": "resources/icons/User_Add.png",
                    "dark": "resources/icons/User_Add.png"
                }
            },
            {
                "command": "testbenchExtension.logout",
                "title": "Testbench: Logout",
                "icon": {
                    "light": "resources/icons/User_Delete.png",
                    "dark": "resources/icons/User_Delete.png"
                }
            },
            {
                "command": "testbenchExtension.changeConnection",
                "title": "TestBench: Change Connection"
            },
            {
                "command": "testbenchExtension.setWorkspaceLocation",
                "title": "TestBench: Set Workspace Location"
            },
            {
                "command": "testbenchExtension.generateTestCases",
                "title": "Generate Test Cases"
            },
            {
                "command": "testbenchExtension.makeRoot",
                "title": "TestBench: Make root"
            },
            {
                "command": "testbenchExtension.displayProjectsList",
                "title": "TestBench: Display Projects List",
                "icon": {
                    "light": "resources/icons/Global_Settings_List.png",
                    "dark": "resources/icons/Global_Settings_List.png"
                }
            },
            {
                "command": "testbenchExtension.refreshTreeView",
                "title": "TestBench: Refresh Tree View",
                "icon": {
                    "light": "resources/icons/Action_Refresh.png",
                    "dark": "resources/icons/Action_Refresh.png"
                }
            },
            {
                "command": "testbenchExtension.getCycleStructure",
                "title": "TestBench: Get Cycle Structure"
            },
            {
                "command": "testbenchExtension.displayCommands",
                "title": "TestBench: Display Commands",
                "icon": {
                    "light": "resources/icons/lightbulb16.png",
                    "dark": "resources/icons/lightbulb16.png"
                }
            },
            {
                "command": "testbenchExtension.showExtensionSettings",
                "title": "TestBench: Show Extension Settings",
                "icon": {
                    "light": "resources/icons/cog_edit.png",
                    "dark": "resources/icons/cog_edit.png"
                }
            },
            {
                "command": "testbenchExtension.getProjectList",
                "title": "TestBench: Get Project List"
            }
        ],
        "views": {
            "testBenchExplorer": [
                {
                    "id": "projectManagementTree",
                    "name": "Project Management Tree"
                },
                {
                    "id": "testThemeTree",
                    "name": "Test Theme Tree"
                }
            ]
        },
        "menus": {
            "view/title": [
                {
                    "command": "testbenchExtension.login",
                    "group": "navigation@1",
                    "title": "Testbench: Login",
                    "when": "!testbenchExtension.connectionActive",
                    "icon": {
                        "light": "resources/icons/User_Add.png",
                        "dark": "resources/icons/User_Add.png"
                    }
                },
                {
                    "command": "testbenchExtension.logout",
                    "group": "navigation@2",
                    "title": "Testbench: Logout",
                    "when": "testbenchExtension.connectionActive",
                    "icon": {
                        "light": "resources/icons/User_Delete.png",
                        "dark": "resources/icons/User_Delete.png"
                    }
                },
                {
                    "command": "testbenchExtension.showExtensionSettings",
                    "group": "navigation@3"
                },
                {
                    "command": "testbenchExtension.displayCommands",
                    "group": "navigation@4"
                },
                {
                    "command": "testbenchExtension.displayProjectsList",
                    "group": "navigation@5"
                },
                {
                    "command": "testbenchExtension.refreshTreeView",
                    "group": "navigation@6"
                }
            ],
            "view/item/context": [
                {
                    "command": "testbenchExtension.generateTestCases",
                    "when": "view == projectManagementTree && viewItem == cycle",
                    "group": "inline"
                },
                {
                    "command": "testbenchExtension.makeRoot",
                    "when": "(view == projectManagementTree || view == testThemeTree) && (viewItem == project || viewItem == tov || viewItem == version || viewItem == testtheme)",
                    "group": "navigation"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "testBenchExplorer",
                    "title": "TestBench",
                    "icon": "resources/icons/iTB-EE-Logo-22x20.png"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "webpack",
        "watch": "webpack --watch",
        "package": "webpack --mode production --devtool hidden-source-map",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/base-64": "^1.0.2",
        "@types/cheerio": "^0.22.35",
        "@types/mocha": "^10.0.7",
        "@types/node": "20.x",
        "@types/unzipper": "^0.10.10",
        "@types/vscode": "^1.91.0",
        "@typescript-eslint/eslint-plugin": "^7.14.1",
        "@typescript-eslint/parser": "^7.11.0",
        "@vscode/test-cli": "^0.0.9",
        "@vscode/test-electron": "^2.4.0",
        "base-64": "^1.0.0",
        "eslint": "^8.57.0",
        "ts-loader": "^9.5.1",
        "typescript": "^5.4.5",
        "webpack": "^5.92.1",
        "webpack-cli": "^5.1.4"
    },
    "dependencies": {
        "axios": "^1.7.2",
        "cheerio": "^1.0.0",
        "unzipper": "^0.12.3"
    }
}
