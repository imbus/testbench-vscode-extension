{
    "name": "testbench-extension",
    "publisher": "imbus",
    "displayName": "TestBench Extension",
    "description": "A Visual Studio Code extension for TestBench.",
    "icon": "resources/icons/testbench-logo.png",
    "version": "0.4.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/imbus/testbench-vs-code-extension"
    },
    "engines": {
        "vscode": "^1.101.0"
    },
    "homepage": "https://github.com/imbus/testbench-vs-code-extension",
    "bugs": {
        "url": "https://github.com/imbus/testbench-vs-code-extension/issues",
        "email": "egegirit@imbus.de"
    },
    "keywords": [
        "TestBench",
        "imbus",
        "testing",
        "test automation",
        "robot framework"
    ],
    "pricing": "Free",
    "license": "SEE LICENSE IN LICENSE.md",
    "categories": [
        "Testing"
    ],
    "activationEvents": [],
    "main": "./dist/extension.js",
    "contributes": {
        "authentication": [
            {
                "label": "TestBench",
                "id": "testbench-auth"
            }
        ],
        "configuration": [
            {
                "title": "Login",
                "properties": {
                    "testbenchExtension.automaticLoginAfterExtensionActivation": {
                        "type": "boolean",
                        "default": false,
                        "description": "If enabled, the extension will automatically attempt to log in to the TestBench server using the last used connection after the extension is activated.",
                        "order": 1,
                        "scope": "resource"
                    }
                }
            },
            {
                "title": "Logger",
                "properties": {
                    "testbenchExtension.testbenchLogLevel": {
                        "type": "string",
                        "description": "Sets the minimum log level for the extension. Logs are saved in the log folder inside the .testbench directory within the workspace.",
                        "default": "Info",
                        "order": 9,
                        "enum": [
                            "No logging",
                            "Trace",
                            "Debug",
                            "Info",
                            "Warn",
                            "Error"
                        ],
                        "enumDescriptions": [
                            "Disable logging",
                            "Most detailed information",
                            "Detailed information",
                            "Information messages",
                            "Warning messages",
                            "Error messages"
                        ],
                        "scope": "resource"
                    }
                }
            },
            {
                "title": "TestBench2RobotFramework",
                "properties": {
                    "testbenchExtension.UseConfigurationFile": {
                        "type": "boolean",
                        "propertyNames": true,
                        "description": "If enabled, testbench2robotframework will prioritize the settings specified in the pyproject.toml over those specified in the extension settings.",
                        "default": false,
                        "order": 10,
                        "scope": "window"
                    },
                    "testbenchExtension.cleanFilesBeforeTestGeneration": {
                        "type": "boolean",
                        "default": true,
                        "description": "Deletes all files present in the output directory before new test suites are created.",
                        "order": 11,
                        "scope": "window"
                    },
                    "testbenchExtension.fullyQualifiedKeywords": {
                        "type": "boolean",
                        "default": false,
                        "description": "Option to call Robot Framework keywords by their fully qualified name in the generated test suites.",
                        "order": 12,
                        "scope": "window"
                    },
                    "testbenchExtension.outputDirectory": {
                        "type": "string",
                        "description": "Directory or ZIP archive where the generated test suites will be created. The path is relative to the workspace location.",
                        "default": "tests",
                        "order": 13,
                        "scope": "window"
                    },
                    "testbenchExtension.compoundInteractionLogging": {
                        "type": "string",
                        "description": "Mode for logging compound TestBench interactions.",
                        "order": 14,
                        "default": "GROUP",
                        "enum": [
                            "GROUP",
                            "COMMENT",
                            "NONE"
                        ],
                        "enumDescriptions": [
                            "Group",
                            "Comment",
                            "None"
                        ],
                        "scope": "window"
                    },
                    "testbenchExtension.logSuiteNumbering": {
                        "type": "boolean",
                        "default": false,
                        "description": "Enables logging of the test suite numbering.",
                        "order": 15,
                        "scope": "window"
                    },
                    "testbenchExtension.resourceDirectoryPath": {
                        "type": "string",
                        "description": "Directory containing the Robot Framework resource files. The path is relative to the workspace location. Import paths of Robot Framework resources will be prefixed with this path.",
                        "order": 16,
                        "default": "",
                        "scope": "window"
                    },
                    "testbenchExtension.libraryMarker": {
                        "type": "array",
                        "description": "Marker that can be used to identify TestBench Subdivisions that correspond to Robot Framework libraries. Subdivisions that end with this marker will be considered as Robot Framework libraries.",
                        "items": {
                            "type": "string"
                        },
                        "default": [
                            "[Robot-Library]"
                        ],
                        "order": 17,
                        "scope": "window"
                    },
                    "testbenchExtension.libraryRoot": {
                        "type": "array",
                        "description": "TestBench root subdivision whose direct children correspond to Robot Framework resources.",
                        "items": {
                            "type": "string"
                        },
                        "default": [
                            "RF",
                            "RF-Library"
                        ],
                        "order": 18,
                        "scope": "window"
                    },
                    "testbenchExtension.resourceRootRegex": {
                        "type": "string",
                        "description": "Regular expression that can be used to identify the TestBench Subdivision that corresponds to the <resource-directory>. Resources will be imported relative to this Subdivision based on the test elements structure in TestBench.",
                        "default": "resources",
                        "order": 19,
                        "scope": "window"
                    },
                    "testbenchExtension.resourceMarker": {
                        "type": "array",
                        "description": "Marker that can be used to identify TestBench Subdivisions that correspond to Robot Framework resources. Subdivisions that end with this marker will be considered as Robot Framework resources.",
                        "items": {
                            "type": "string"
                        },
                        "default": [
                            "[Robot-Resource]"
                        ],
                        "order": 20,
                        "scope": "window"
                    },
                    "testbenchExtension.resourceRoot": {
                        "type": "array",
                        "description": "TestBench root subdivision whose direct children correspond to Robot Framework resources.",
                        "items": {
                            "type": "string"
                        },
                        "default": [
                            "RF-Resource"
                        ],
                        "order": 21,
                        "scope": "window"
                    },
                    "testbenchExtension.libraryMapping": {
                        "type": "array",
                        "markdownDescription": "Optional mapping of TestBench Subdivisions to Robot Framework libraries. Must be specified in the format:\n`<TestBench Subdivision Name>:<Robot Framework Library import>`",
                        "items": {
                            "type": "string"
                        },
                        "default": [],
                        "order": 22,
                        "scope": "window"
                    },
                    "testbenchExtension.resourceMapping": {
                        "type": "array",
                        "markdownDescription": "Optional mapping of TestBench Subdivisions to Robot Framework resources. Must be specified in the format:\n`<TestBench Subdivision Name>:<Robot Framework Resource import>.`",
                        "items": {
                            "type": "string"
                        },
                        "default": [],
                        "order": 23,
                        "scope": "window"
                    },
                    "testbenchExtension.outputXmlFilePath": {
                        "type": "string",
                        "description": "The relative file path where the output XML file (Robotframework test results) is stored. If not set, the extension will prompt the user to select a output.xml file location when importing results to testbench server. The path is relative to the workspace location. Used for importing the test results to the TestBench Server.",
                        "default": "results/output.xml",
                        "order": 24,
                        "scope": "window"
                    }
                }
            },
            {
                "title": "Test Generation",
                "properties": {
                    "testbenchExtension.clearInternalTestbenchDirectoryBeforeTestGeneration": {
                        "type": "boolean",
                        "default": false,
                        "description": "Deletes all files, excluding log files, from the internal `.testbench` directory before generating tests.",
                        "order": 1,
                        "scope": "resource"
                    },
                    "testbenchExtension.openTestingViewAfterGeneration": {
                        "type": "boolean",
                        "description": "If enabled, the testing view will be opened automatically after test generation is completed.",
                        "default": false,
                        "order": 1,
                        "scope": "window"
                    },
                    "testbenchExtension.clearReportAfterProcessing": {
                        "type": "boolean",
                        "default": true,
                        "description": "Remove the downloaded report file automatically after processing it.",
                        "order": 3,
                        "scope": "resource"
                    }
                }
            },
            {
                "title": "Connection",
                "properties": {
                    "testbenchExtension.certificatePath": {
                        "type": "string",
                        "description": "Path to the public TestBench certificate .pem file relative to the workspace location.",
                        "order": 1,
                        "scope": "resource"
                    }
                }
            }
        ],
        "commands": [
            {
                "command": "testbenchExtension.login",
                "title": "Login / Switch Connection",
                "icon": {
                    "light": "resources/icons/login.svg",
                    "dark": "resources/icons/login.svg"
                }
            },
            {
                "command": "testbenchExtension.logout",
                "title": "Logout",
                "icon": {
                    "light": "resources/icons/logout.svg",
                    "dark": "resources/icons/logout.svg"
                }
            },
            {
                "command": "testbenchExtension.clearInternalTestbenchFolder",
                "title": "Clear Temporary Files",
                "icon": {
                    "light": "resources/icons/clearInternalTestbenchFolder-light.svg",
                    "dark": "resources/icons/clearInternalTestbenchFolder-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.generateTestCasesForCycle",
                "title": "Generate Robot Framework Test Suites (Cycle based)",
                "icon": {
                    "light": "resources/icons/robot-light.svg",
                    "dark": "resources/icons/robot-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.generateTestCasesForTestThemeOrTestCaseSet",
                "title": "Generate Robot Framework Test Suites",
                "icon": {
                    "light": "resources/icons/robot-light.svg",
                    "dark": "resources/icons/robot-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.generateTestsForTestThemeTreeItemFromTOV",
                "title": "Generate Robot Framework Test Suites",
                "icon": {
                    "light": "resources/icons/robot-light.svg",
                    "dark": "resources/icons/robot-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.openAndRevealGeneratedRobotFile",
                "title": "Open Generated Test Suite",
                "icon": {
                    "light": "resources/icons/open-light.svg",
                    "dark": "resources/icons/open-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.generateTestCasesForTOV",
                "title": "Generate Robot Framework Test Suites (TOV based)",
                "icon": {
                    "light": "resources/icons/robot-light.svg",
                    "dark": "resources/icons/robot-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.openTOVFromProjectsView",
                "title": "Open Test Object Version",
                "icon": {
                    "light": "resources/icons/open-light.svg",
                    "dark": "resources/icons/open-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.openCycleFromProjectsView",
                "title": "Open Test Cycle",
                "icon": {
                    "light": "resources/icons/open-light.svg",
                    "dark": "resources/icons/open-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.makeRoot",
                "title": "Make root"
            },
            {
                "command": "testbenchExtension.resetProjectTreeViewRoot",
                "title": "Reset Projects View Root"
            },
            {
                "command": "testbenchExtension.resetTestThemeTreeViewRoot",
                "title": "Reset Test Themes View Root"
            },
            {
                "command": "testbenchExtension.fetchTovStructure",
                "title": "TestBench: Get TOV Structure"
            },
            {
                "command": "testbenchExtension.displayAllProjects",
                "title": "Open Projects View",
                "icon": {
                    "light": "resources/icons/menu-light.svg",
                    "dark": "resources/icons/menu-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.refreshProjectTreeView",
                "title": "Refresh Projects",
                "when": "view == projectManagementTree",
                "icon": {
                    "light": "resources/icons/refresh-light.svg",
                    "dark": "resources/icons/refresh-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.refreshTestThemeTreeView",
                "title": "Refresh Test Themes",
                "when": "view == testThemeTree",
                "group": "navigation@1",
                "icon": {
                    "light": "resources/icons/refresh-light.svg",
                    "dark": "resources/icons/refresh-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.displayFiltersForTestThemeTreeON",
                "title": "Display Test Theme Filters",
                "when": "view == testbench.testThemes && !testbenchExtension.testThemeTreeHasFilters",
                "icon": {
                    "light": "resources/icons/filter-light.svg",
                    "dark": "resources/icons/filter-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.displayFiltersForTestThemeTreeOFF",
                "title": "Display Test Theme Filters",
                "when": "view == testbench.testThemes && testbenchExtension.testThemeTreeHasFilters",
                "icon": {
                    "light": "resources/icons/filter-off-light.svg",
                    "dark": "resources/icons/filter-off-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.showExtensionSettings",
                "title": "Open Extension Settings",
                "icon": {
                    "light": "resources/icons/settings-light.svg",
                    "dark": "resources/icons/settings-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.readAndImportTestResultsToTestbench",
                "title": "Upload Execution Results To Testbench",
                "icon": {
                    "light": "resources/icons/upload-light.svg",
                    "dark": "resources/icons/upload-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.importTestResultsToTestbench",
                "title": "Upload Execution Results To Testbench",
                "icon": {
                    "light": "resources/icons/upload-light.svg",
                    "dark": "resources/icons/upload-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.refreshTestElementsTree",
                "title": "Refresh Test Elements",
                "when": "view == testbench.testElements",
                "group": "navigation",
                "icon": {
                    "light": "resources/icons/refresh-light.svg",
                    "dark": "resources/icons/refresh-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.openAvailableSubdivisionInTestElementsView",
                "title": "Open Resource",
                "when": "view == testbench.testElements && viewItem == 'testElement.subdivision.resource.available'",
                "icon": {
                    "light": "resources/icons/open-light.svg",
                    "dark": "resources/icons/open-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.openMissingSubdivisionInTestElementsView",
                "title": "Create Resource",
                "when": "view == testbench.testElements && viewItem == 'testElement.subdivision.resource.missing'",
                "icon": "$(new-file)"
            },
            {
                "command": "testbenchExtension.openSubdivisionFolderInExplorer",
                "title": "Open in Explorer View",
                "when": "view == testbench.testElements && viewItem == 'testElement.subdivision.folder'",
                "icon": {
                    "light": "resources/icons/open-light.svg",
                    "dark": "resources/icons/open-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.openInteractionInTestElementsView",
                "title": "Open Resource",
                "when": "view == testbench.testElements && viewItem == 'testElement.interaction.resource.available'",
                "icon": {
                    "light": "resources/icons/open-light.svg",
                    "dark": "resources/icons/open-dark.svg"
                }
            },
            {
                "command": "testbenchExtension.createMissingParentResourceForInteraction",
                "title": "Create Resource",
                "when": "view == testbench.testElements && viewItem == 'testElement.interaction.resource.missing'",
                "icon": "$(new-file)"
            },
            {
                "command": "testbenchExtension.openIssueReporter",
                "title": "TestBench: Open Issue Reporter"
            },
            {
                "command": "testbenchExtension.checkForCycleDoubleClick",
                "title": "Handle Cycle Click"
            },
            {
                "command": "testbenchExtension.clearAllExtensionData",
                "title": "TestBench: Clear All Extension Data",
                "icon": {
                    "light": "resources/icons/clearInternalTestbenchFolder-light.svg",
                    "dark": "resources/icons/clearInternalTestbenchFolder-dark.svg"
                }
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "testBenchExplorer",
                    "title": "TestBench",
                    "icon": "resources/icons/testbench-logo.png"
                }
            ]
        },
        "views": {
            "testBenchExplorer": [
                {
                    "type": "webview",
                    "id": "testbenchExtension.webView",
                    "name": "Login to TestBench",
                    "when": "!testbenchExtension.connectionActive",
                    "icon": "resources/icons/login.svg"
                },
                {
                    "id": "testbench.projects",
                    "name": "Projects",
                    "when": "testbenchExtension.connectionActive && testbenchExtension.showProjectsTree",
                    "icon": "resources/icons/project-dark.svg"
                },
                {
                    "id": "testbench.testThemes",
                    "name": "Test Themes",
                    "when": "testbenchExtension.connectionActive && testbenchExtension.showTestThemesTree",
                    "icon": "resources/icons/TestThemeOriginal-dark.svg"
                },
                {
                    "id": "testbench.testElements",
                    "name": "Test Elements",
                    "when": "testbenchExtension.connectionActive && testbenchExtension.showTestElementsTree",
                    "icon": "resources/icons/test-elements-dark.svg"
                }
            ]
        },
        "menus": {
            "commandPalette": [
                {
                    "command": "testbenchExtension.makeRoot",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.resetProjectTreeViewRoot",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.resetTestThemeTreeViewRoot",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.fetchTovStructure",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.displayAllProjects",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.refreshProjectTreeView",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.refreshTestThemeTreeView",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.showExtensionSettings",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.readAndImportTestResultsToTestbench",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.importTestResultsToTestbench",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.refreshTestElementsTree",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.openAvailableSubdivisionInTestElementsView",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.openMissingSubdivisionInTestElementsView",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.openSubdivisionFolderInExplorer",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.openInteractionInTestElementsView",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.createMissingParentResourceForInteraction",
                    "when": "false"
                },
                {
                    "command": "testbenchExtension.checkForCycleDoubleClick",
                    "when": "false"
                }
            ],
            "view/title": [
                {
                    "command": "testbenchExtension.login",
                    "group": "navigation@1",
                    "title": "Login",
                    "when": "!testbenchExtension.connectionActive && (view == testbench.projects)",
                    "icon": {
                        "light": "resources/icons/login.svg",
                        "dark": "resources/icons/login.svg"
                    }
                },
                {
                    "command": "testbenchExtension.logout",
                    "group": "navigation@2",
                    "title": "Logout",
                    "when": "testbenchExtension.connectionActive && (view == testbench.projects)",
                    "icon": {
                        "light": "resources/icons/logout.svg",
                        "dark": "resources/icons/logout.svg"
                    }
                },
                {
                    "command": "testbenchExtension.refreshProjectTreeView",
                    "group": "navigation@3",
                    "when": "view == testbench.projects",
                    "icon": {
                        "light": "resources/icons/refresh-light.svg",
                        "dark": "resources/icons/refresh-dark.svg"
                    }
                },
                {
                    "command": "testbenchExtension.displayAllProjects",
                    "group": "navigation@2",
                    "when": "view == testbench.testThemes",
                    "icon": {
                        "light": "resources/icons/menu-light.svg",
                        "dark": "resources/icons/menu-dark.svg"
                    }
                },
                {
                    "command": "testbenchExtension.displayAllProjects",
                    "group": "navigation@2",
                    "when": "view == testbench.testElements",
                    "icon": {
                        "light": "resources/icons/menu-light.svg",
                        "dark": "resources/icons/menu-dark.svg"
                    }
                },
                {
                    "command": "testbenchExtension.refreshTestThemeTreeView",
                    "group": "navigation@1",
                    "when": "view == testbench.testThemes",
                    "icon": {
                        "light": "resources/icons/refresh-light.svg",
                        "dark": "resources/icons/refresh-dark.svg"
                    }
                },
                {
                    "command": "testbenchExtension.displayFiltersForTestThemeTreeOFF",
                    "when": "view == testbench.testThemes && !testbenchExtension.testThemeTreeHasFilters",
                    "group": "navigation@3",
                    "icon": {
                        "light": "resources/icons/filter-off-light.svg",
                        "dark": "resources/icons/filter-off-dark.svg"
                    }
                },
                {
                    "command": "testbenchExtension.displayFiltersForTestThemeTreeON",
                    "when": "view == testbench.testThemes && testbenchExtension.testThemeTreeHasFilters",
                    "group": "navigation@3",
                    "icon": {
                        "light": "resources/icons/filter-light.svg",
                        "dark": "resources/icons/filter-dark.svg"
                    }
                },
                {
                    "command": "testbenchExtension.showExtensionSettings",
                    "group": "navigation@8",
                    "when": "view == testbench.projects || view == testbenchExtension.webView"
                },
                {
                    "command": "testbenchExtension.refreshTestElementsTree",
                    "title": "Refresh Test Elements",
                    "when": "view == testbench.testElements",
                    "group": "navigation",
                    "icon": {
                        "light": "resources/icons/refresh-light.svg",
                        "dark": "resources/icons/refresh-dark.svg"
                    }
                }
            ],
            "view/item/context": [
                {
                    "command": "testbenchExtension.generateTestCasesForCycle",
                    "when": "view == testbench.projects && viewItem == Cycle",
                    "group": "inline@1"
                },
                {
                    "command": "testbenchExtension.openCycleFromProjectsView",
                    "when": "view == testbench.projects && viewItem == Cycle",
                    "group": "inline@2"
                },
                {
                    "command": "testbenchExtension.generateTestCasesForTOV",
                    "when": "view == testbench.projects && (viewItem == Version || viewItem == customRoot.Version)",
                    "group": "inline@1"
                },
                {
                    "command": "testbenchExtension.openTOVFromProjectsView",
                    "when": "view == testbench.projects && (viewItem == Version || viewItem == customRoot.Version)",
                    "group": "inline@2"
                },
                {
                    "command": "testbenchExtension.generateTestCasesForTestThemeOrTestCaseSet",
                    "when": "view == 'testbench.testThemes' && testbenchExtension.isTestThemeOpenedFromCycle && viewItem =~ /(TestThemeNode|TestCaseSetNode)(\\.hasRobotFile)?$/",
                    "group": "inline@1"
                },
                {
                    "command": "testbenchExtension.generateTestsForTestThemeTreeItemFromTOV",
                    "when": "view == 'testbench.testThemes' && !testbenchExtension.isTestThemeOpenedFromCycle && viewItem =~ /(TestThemeNode|TestCaseSetNode)(\\.hasRobotFile)?$/",
                    "group": "inline@2"
                },
                {
                    "command": "testbenchExtension.openAndRevealGeneratedRobotFile",
                    "when": "view == 'testbench.testThemes' && viewItem =~ /\\.hasRobotFile$/",
                    "group": "inline@3"
                },
                {
                    "command": "testbenchExtension.readAndImportTestResultsToTestbench",
                    "when": "view == 'testbench.testThemes' && viewItem =~ /MarkedForImport/",
                    "group": "inline@2",
                    "icon": {
                        "light": "resources/icons/upload-light.svg",
                        "dark": "resources/icons/upload-dark.svg"
                    }
                },
                {
                    "command": "testbenchExtension.makeRoot",
                    "when": "(view == testbench.projects && viewItem == Project) || (view == testbench.testThemes && (viewItem == TestThemeNode || viewItem == 'MarkedForImport.TestThemeNode' || viewItem == 'MarkedForGeneration.TestThemeNode' || viewItem == 'openedFromCycle.TestThemeNode' || viewItem == 'openedFromCycle.MarkedForImport.TestThemeNode' || viewItem == 'openedFromCycle.MarkedForGeneration.TestThemeNode'))",
                    "group": "navigation"
                },
                {
                    "command": "testbenchExtension.resetProjectTreeViewRoot",
                    "when": "view == testbench.projects && viewItem =~ /customRoot/",
                    "group": "navigation@1",
                    "title": "Reset Custom Root"
                },
                {
                    "command": "testbenchExtension.resetTestThemeTreeViewRoot",
                    "when": "view == 'testbench.testThemes' && viewItem =~ /customRoot/",
                    "group": "navigation@1",
                    "title": "Reset Custom Root"
                },
                {
                    "command": "testbenchExtension.openAvailableSubdivisionInTestElementsView",
                    "when": "view == testbench.testElements && viewItem == 'testElement.subdivision.resource.available'",
                    "group": "inline@1"
                },
                {
                    "command": "testbenchExtension.openMissingSubdivisionInTestElementsView",
                    "when": "view == testbench.testElements && viewItem == 'testElement.subdivision.resource.missing'",
                    "group": "inline@1"
                },
                {
                    "command": "testbenchExtension.openSubdivisionFolderInExplorer",
                    "when": "view == testbench.testElements && viewItem == 'testElement.subdivision.folder'",
                    "group": "inline@1"
                },
                {
                    "command": "testbenchExtension.openInteractionInTestElementsView",
                    "when": "view == testbench.testElements && viewItem == 'testElement.interaction.resource.available'",
                    "group": "inline@1"
                },
                {
                    "command": "testbenchExtension.createMissingParentResourceForInteraction",
                    "when": "view == testbench.testElements && viewItem == 'testElement.interaction.resource.missing'",
                    "group": "inline@1"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "tsc -p ./",
        "watch": "webpack --watch",
        "package": "webpack --mode production --devtool hidden-source-map",
        "vsix-package": "vsce package",
        "compile-tests": "tsc -p ./",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile",
        "test": "node ./out/test/runTest.js",
        "prettier-format": "prettier --config .prettierrc 'src/**/*.ts' --write",
        "lint": "eslint --config eslint.config.mjs .",
        "prepare": "husky",
        "release": "semantic-release",
        "commit:cz": "git-cz",
        "test:unit": "npm run compile-tests && mocha ./out/test/suite/**/*.test.js --timeout 10000",
        "test:coverage": "npm run compile-tests && nyc --reporter=lcov --reporter=text mocha ./out/test/suite/**/*.test.js --timeout 10000",
        "format:check": "prettier --check .",
        "commit:helper": "node scripts/commit.js",
        "release:manual": "node scripts/manual-release.js"
    },
